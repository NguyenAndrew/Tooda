{
  "name": "tooda",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "node scripts/dev-detach.js",
    "dev:attach": "node scripts/copy-mermaid.js && astro dev",
    "build": "node scripts/copy-mermaid.js && astro build",
    "preview": "astro preview",
    "lint": "eslint src/ --max-warnings 0 && npm run lint:api",
    "lint:api": "node --experimental-strip-types scripts/lint-openapi.mjs",
    "postinstall": "npm run install:playwright",
    "install:playwright": "npx playwright install --with-deps chromium",
    "test": "npm run lint && playwright test",
    "test:ci": "playwright test",
    "make-gifs": "node scripts/make-gifs.js",
    "generate-healthcare-pngs": "node scripts/generate-healthcare-pngs.js"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@excalidraw/excalidraw": "^0.18.0",
    "@mermaid-js/layout-elk": "^0.2.0",
    "astro": "^5.18.0",
    "mermaid": "^11.12.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reveal.js": "^5.2.1",
    "swagger-ui-dist": "^5.32.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@playwright/test": "^1.58.2",
    "@stoplight/spectral-cli": "^6.15.0",
    "@types/reveal.js": "^5.2.2",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "gif-encoder-2": "^1.0.5",
    "pngjs": "^7.0.0",
    "tailwindcss": "^3.4.19",
    "typescript-eslint": "^8.56.1"
  }
}
