---
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content="Slide Deck – An overview of Tooda, the browser-based architecture diagram tool" />
    <title>Slide Deck | Tooda</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme = stored === 'light' ? 'light' : 'dark';
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg-color: #f8fafc;
        --grad1: rgba(99,102,241,0.12);
        --grad2: rgba(139,92,246,0.08);
        --grad3: rgba(56,189,248,0.06);
        --grid-line: rgba(99,102,241,0.03);
      }

      :root.dark {
        --bg-color: #0f172a;
        --grad1: rgba(99,102,241,0.25);
        --grad2: rgba(139,92,246,0.15);
        --grad3: rgba(56,189,248,0.12);
        --grid-line: rgba(99,102,241,0.06);
      }

      body {
        background-color: var(--bg-color);
        background-image:
          radial-gradient(ellipse 80% 60% at 50% -10%, var(--grad1) 0%, transparent 70%),
          radial-gradient(ellipse 50% 40% at 90% 80%, var(--grad2) 0%, transparent 60%),
          radial-gradient(ellipse 40% 40% at 10% 90%, var(--grad3) 0%, transparent 60%);
        @apply min-h-dvh font-sans text-slate-900 dark:text-slate-50;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--grid-line) 1px, transparent 1px),
          linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 0;
      }

      .page-content {
        position: relative;
        z-index: 1;
      }

      @keyframes glow-pulse {
        0%, 100% { filter: drop-shadow(0 0 16px rgba(139,92,246,0.5)); }
        50%       { filter: drop-shadow(0 0 36px rgba(99,102,241,0.8)); }
      }

      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-6px); }
      }

      /* ── Reveal.js slide container ── */
      .reveal {
        height: calc(100dvh - 160px);
        overflow: hidden;
        /* Reset Reveal.js background so our page background shows through */
        background: transparent;
      }

      /* ── Slide content wrapper (inside each Reveal.js section) ── */
      .slide {
        display: flex;
        flex-direction: column;
        justify-content: center;
        width: 100%;
        @apply mx-auto max-w-4xl px-6 py-12;
      }

      /* ── Slide elements ── */
      .slide-badge {
        animation: float 4s ease-in-out infinite;
        @apply mb-6 inline-flex items-center gap-2 self-start rounded-full border border-indigo-500/40 bg-indigo-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-300;
      }

      .slide-title {
        animation: glow-pulse 3s ease-in-out infinite;
        @apply mb-6 bg-gradient-to-br from-indigo-400 via-violet-400 to-sky-400 bg-clip-text text-[clamp(2.2rem,6vw,4rem)] font-extrabold leading-none tracking-tight text-transparent;
      }

      .slide-subtitle {
        @apply mb-4 text-[clamp(1rem,2.5vw,1.3rem)] leading-relaxed text-slate-600 dark:text-slate-300;
      }

      .slide-body {
        @apply text-base leading-relaxed text-slate-500 dark:text-slate-400;
      }

      /* ── Feature grid ── */
      .feature-grid {
        @apply mt-8 grid gap-4 sm:grid-cols-2;
      }

      .feature-item {
        @apply rounded-xl border border-slate-200/80 bg-white/70 p-5 backdrop-blur-sm dark:border-slate-700/60 dark:bg-slate-800/60;
      }

      .feature-item-icon {
        @apply mb-2 text-2xl;
      }

      .feature-item-title {
        @apply mb-1 text-base font-bold text-slate-800 dark:text-slate-100;
      }

      .feature-item-desc {
        @apply text-sm leading-relaxed text-slate-600 dark:text-slate-400;
      }

      /* ── CTA links ── */
      .cta-primary {
        @apply inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-500 px-6 py-3 text-sm font-semibold text-white no-underline shadow-lg shadow-indigo-500/25 transition-all duration-200 active:scale-95 active:shadow-md active:shadow-indigo-500/15 active:duration-75;
      }

      @media (hover: hover) {
        .cta-primary:hover {
          @apply -translate-y-0.5 shadow-xl shadow-indigo-500/35;
        }
      }

      /* ── Navigation bar ── */
      .slide-nav {
        position: sticky;
        bottom: 0;
        z-index: 10;
        @apply flex flex-col gap-2 border-t border-slate-200/80 bg-white/90 px-6 py-4 backdrop-blur-md dark:border-slate-700/60 dark:bg-slate-900/90;
      }

      .slide-nav-controls {
        @apply flex items-center justify-between gap-4;
      }

      @media (min-width: 640px) {
        .slide-nav {
          @apply flex-row items-center;
        }

        .slide-nav-controls {
          @apply flex-1;
        }
      }

      .nav-btn {
        /* touch-action: manipulation removes the 300 ms tap delay on mobile
           and disables double-tap zoom, so button taps respond immediately */
        touch-action: manipulation;
        @apply inline-flex items-center gap-2 rounded-xl border border-slate-300 bg-slate-100 px-5 py-2.5 text-sm font-semibold text-slate-600 no-underline transition-all duration-200 active:scale-95 active:duration-75 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300;
      }

      @media (hover: hover) {
        .nav-btn:hover:not(:disabled) {
          @apply border-indigo-400/50 bg-slate-200 text-slate-900 dark:border-indigo-500/50 dark:bg-slate-700 dark:text-slate-50;
        }
      }

      .nav-btn:disabled {
        @apply cursor-not-allowed opacity-30;
      }


      .slide-counter {
        @apply text-sm font-semibold text-slate-500 dark:text-slate-400;
      }

      /* ── Progress dots ── */
      .progress-dots {
        @apply flex items-center gap-2;
      }

      .dot {
        @apply h-2 w-2 cursor-pointer rounded-full bg-slate-300 transition-all duration-200 dark:bg-slate-600;
      }

      .dot.active {
        @apply w-5 bg-indigo-500;
      }

      /* ── Back link ── */
      nav.back {
        @apply px-6 pt-6 pb-2;
      }

      nav.back a {
        @apply text-[0.9rem] text-violet-600 no-underline dark:text-violet-400;
      }

      nav.back a:hover {
        @apply underline;
      }

      /* ── Code block ── */
      .code-block {
        @apply rounded-xl border border-slate-200/80 bg-slate-50 p-4 font-mono text-sm text-slate-600 dark:border-slate-700/60 dark:bg-slate-900 dark:text-slate-300;
      }

      /* ── Theme toggle button ── */
      .theme-toggle-btn {
        @apply fixed right-4 top-4 z-50 flex h-10 w-10 items-center justify-center rounded-full border border-slate-300 bg-white/80 text-slate-600 shadow-md backdrop-blur-sm transition-all duration-200 hover:border-indigo-400 hover:text-slate-900 dark:border-slate-700 dark:bg-slate-800/80 dark:text-slate-300 dark:hover:border-indigo-500/50 dark:hover:text-slate-50;
      }

      /* ── Mobile landscape: flex column so the deck fills every pixel ── */
      @media (orientation: landscape) and (max-height: 500px) {
        /* Prevent the body from growing taller than the viewport */
        body {
          height: 100dvh;
          overflow: hidden;
        }

        /* Stack children into a full-height flex column */
        .page-content {
          display: flex;
          flex-direction: column;
          height: 100%;
          overflow: hidden;
        }

        /* Compact back nav */
        nav.back {
          flex: 0 0 auto;
          padding: 4px 16px 2px;
        }

        /* In landscape: hide the Back link so the reveal gets the full viewport height. */
        nav.back {
          display: none;
        }

        /* Compact slide nav – one row, no longer needs sticky inside a flex column */
        .slide-nav {
          flex: 0 0 auto;
          position: relative;
          flex-direction: row;
          align-items: center;
          padding: 5px 12px;
          gap: 8px;
        }

        .slide-nav-controls {
          flex: 1;
        }

        /* Hide progress dots in landscape to save vertical space in the nav */
        #progress-dots {
          display: none;
        }

        /* Reveal fills whatever height is left */
        .reveal {
          flex: 1 1 auto;
          min-height: 0;
          height: 0 !important; /* flex-basis 0 lets flex-grow drive the size */
        }

        /* Compact slide content */
        .slide {
          justify-content: flex-start;
          @apply px-4 py-2;
        }

        .slide-badge {
          @apply mb-2 py-0.5 px-3 text-[0.65rem];
        }

        .slide-title {
          font-size: clamp(1.3rem, 5vw, 2.2rem);
          @apply mb-2;
        }

        .slide-subtitle {
          font-size: clamp(0.75rem, 2vw, 0.95rem);
          @apply mb-1 leading-snug;
        }

        .slide-body {
          @apply text-sm leading-snug;
        }

        .feature-grid {
          @apply mt-2 gap-2 grid-cols-2;
        }

        .feature-item {
          @apply p-2.5;
        }

        .feature-item-icon {
          @apply mb-1 text-lg;
        }

        .feature-item-title {
          @apply text-sm;
        }

        .feature-item-desc {
          @apply text-xs leading-snug;
        }

        .nav-btn {
          @apply px-3 py-1.5 text-xs;
        }

      }
    </style>
  </head>
  <body>
    <!-- Theme toggle button -->
    <button id="theme-toggle" type="button" aria-label="Switch to light mode" class="theme-toggle-btn">
      <svg class="hidden size-5 dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="block size-5 dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <div class="page-content">

      <nav class="back">
        <a href="/Tooda/">← Back to Home</a>
      </nav>

      <!-- ═══════════════════════ Reveal.js slide container ═══════════════════════ -->
      <div class="reveal">
        <div class="slides">

          <!-- ═══════════════════════ SLIDE 1 – Welcome ═══════════════════════ -->
          <section aria-label="Slide 1 of 6">
            <div class="slide">
              <span class="slide-badge">✦ Slide Deck</span>
              <h1 class="slide-title">Welcome to Tooda</h1>
              <p class="slide-subtitle">
                A lightweight, browser-based tool for creating and maintaining
                architecture &amp; design diagrams — no install required.
              </p>
              <p class="slide-body">
                Tooda helps software teams visualize complex systems using industry-standard
                notation. Everything runs in the browser using static files, so there is nothing
                to deploy or configure: just open a URL and start exploring.
              </p>
              <p class="mt-4 text-base leading-relaxed text-slate-500 dark:text-slate-400">
                Use the navigation buttons below (or the ← → arrow keys) to move through the slides.
              </p>
            </div>
          </section>

          <!-- ═══════════════════════ SLIDE 2 – C4 Diagrams ═══════════════════════ -->
          <section aria-label="Slide 2 of 6">
            <div class="slide">
              <span class="slide-badge">🏗️ C4 Model</span>
              <h1 class="slide-title">C4 Architecture Diagrams</h1>
              <p class="slide-subtitle">
                Explore real-world system designs at four levels of detail using
                Mermaid-powered C4 notation.
              </p>
              <div class="feature-grid">
                <div class="feature-item">
                  <div class="feature-item-icon">1️⃣</div>
                  <div class="feature-item-title">Level 1 – Context</div>
                  <div class="feature-item-desc">Shows the system and how users and external systems interact with it.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">2️⃣</div>
                  <div class="feature-item-title">Level 2 – Container</div>
                  <div class="feature-item-desc">Zooms in to show the applications, services, and data stores that form the system.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">3️⃣</div>
                  <div class="feature-item-title">Level 3 – Component</div>
                  <div class="feature-item-desc">Reveals the major structural components inside a single container.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">4️⃣</div>
                  <div class="feature-item-title">Level 4 – Code</div>
                  <div class="feature-item-desc">Shows the classes and interfaces that implement a component.</div>
                </div>
              </div>
              <p class="mt-6 text-sm text-slate-500 dark:text-slate-500">
                Built-in examples: Online Banking, E-Commerce, Ride-Sharing, and Tooda itself.
              </p>
            </div>
          </section>

          <!-- ═══════════════════════ SLIDE 3 – Excalidraw ═══════════════════════ -->
          <section aria-label="Slide 3 of 6">
            <div class="slide">
              <span class="slide-badge">✏️ Freehand</span>
              <h1 class="slide-title">Freehand Diagrams</h1>
              <p class="slide-subtitle">
                Sketch architecture ideas freely with Excalidraw's hand-drawn aesthetic —
                full edit, view, and export support built in.
              </p>
              <p class="slide-body">
                Excalidraw diagrams give your architecture visuals a natural, approachable look
                without sacrificing the precision of the C4 model. Each of the four C4 levels is
                available in freehand form for the Healthcare Platform example.
              </p>
              <div class="feature-grid mt-8">
                <div class="feature-item">
                  <div class="feature-item-icon">🖊️</div>
                  <div class="feature-item-title">Edit Mode</div>
                  <div class="feature-item-desc">Modify diagrams interactively directly in the browser canvas.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">👁️</div>
                  <div class="feature-item-title">View Mode</div>
                  <div class="feature-item-desc">Present diagrams in a clean read-only view without UI clutter.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">💾</div>
                  <div class="feature-item-title">Export JSON</div>
                  <div class="feature-item-desc">Download any diagram as a portable Excalidraw JSON file.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">📐</div>
                  <div class="feature-item-title">Responsive Canvas</div>
                  <div class="feature-item-desc">Canvas adapts to any screen size automatically via ResizeObserver.</div>
                </div>
              </div>
            </div>
          </section>

          <!-- ═══════════════════════ SLIDE 4 – API Explorer ═══════════════════════ -->
          <section aria-label="Slide 4 of 6">
            <div class="slide">
              <span class="slide-badge">🔌 API</span>
              <h1 class="slide-title">API Explorer</h1>
              <p class="slide-subtitle">
                Every diagram is also available as a JSON endpoint — explore and test them
                interactively via a built-in Swagger UI.
              </p>
              <p class="slide-body">
                Tooda exposes a fully documented REST-style API so that teams can programmatically
                consume diagram data. The API is described with an OpenAPI 3.0 specification and
                browsable without any extra tooling.
              </p>
              <div class="feature-grid mt-8">
                <div class="feature-item">
                  <div class="feature-item-icon">📄</div>
                  <div class="feature-item-title">C4 Endpoints</div>
                  <div class="feature-item-desc">Fetch full C4 diagram definitions for any of the four built-in examples.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">🖼️</div>
                  <div class="feature-item-title">Excalidraw Endpoints</div>
                  <div class="feature-item-desc">Retrieve Excalidraw element arrays for each C4 level of the Healthcare Platform.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">📑</div>
                  <div class="feature-item-title">OpenAPI Spec</div>
                  <div class="feature-item-desc">Machine-readable OpenAPI 3.0 schema served at <code>/Tooda/api/openapi.json</code>.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">⚡</div>
                  <div class="feature-item-title">Swagger UI</div>
                  <div class="feature-item-desc">Interactive API browser with live request/response testing, no extra tools needed.</div>
                </div>
              </div>
            </div>
          </section>

          <!-- ═══════════════════════ SLIDE 5 – Platform & Tech ═══════════════════════ -->
          <section aria-label="Slide 5 of 6">
            <div class="slide">
              <span class="slide-badge">🔮 Platform</span>
              <h1 class="slide-title">Platform &amp; Technology</h1>
              <p class="slide-subtitle">
                Tooda is built on a modern, zero-server-required stack that deploys as pure
                static files.
              </p>
              <div class="feature-grid">
                <div class="feature-item">
                  <div class="feature-item-icon">🚀</div>
                  <div class="feature-item-title">Astro v5</div>
                  <div class="feature-item-desc">Static-site generator that compiles pages to HTML, CSS, and minimal JS.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">⚛️</div>
                  <div class="feature-item-title">React 18</div>
                  <div class="feature-item-desc">Interactive components like the Excalidraw viewer and 3D visualizer.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">🎨</div>
                  <div class="feature-item-title">Tailwind CSS v3</div>
                  <div class="feature-item-desc">Utility-first CSS for a consistent, responsive, themeable interface.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">🔷</div>
                  <div class="feature-item-title">TypeScript (strict)</div>
                  <div class="feature-item-desc">Full type safety across all source files for reliability and maintainability.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">🌐</div>
                  <div class="feature-item-title">GitHub Pages</div>
                  <div class="feature-item-desc">Automatic deployment via GitHub Actions on every push to <code>main</code>.</div>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">🧪</div>
                  <div class="feature-item-title">Playwright Tests</div>
                  <div class="feature-item-desc">Comprehensive end-to-end test suite covering every page and feature.</div>
                </div>
              </div>
            </div>
          </section>

          <!-- ═══════════════════════ SLIDE 6 – Get Started ═══════════════════════ -->
          <section aria-label="Slide 6 of 6">
            <div class="slide">
              <span class="slide-badge">✅ Get Started</span>
              <h1 class="slide-title">Start Exploring</h1>
              <p class="slide-subtitle">
                Jump straight into any of Tooda's features — everything runs in your browser,
                nothing to install.
              </p>
              <div class="feature-grid mt-2">
                <div class="feature-item">
                  <div class="feature-item-icon">🏗️</div>
                  <div class="feature-item-title">C4 Diagrams</div>
                  <div class="feature-item-desc mb-3">Explore interactive C4 architecture diagrams.</div>
                  <a href="/Tooda/c4?example=banking" class="cta-primary">🏦 Open Banking →</a>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">✏️</div>
                  <div class="feature-item-title">Freehand Diagrams</div>
                  <div class="feature-item-desc mb-3">Sketch with Excalidraw's hand-drawn style.</div>
                  <a href="/Tooda/excalidraw" class="cta-primary">🏥 Open Healthcare →</a>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">🔌</div>
                  <div class="feature-item-title">API Explorer</div>
                  <div class="feature-item-desc mb-3">Test and browse diagram API endpoints.</div>
                  <a href="/Tooda/api" class="cta-primary">⚡ Open API Explorer →</a>
                </div>
                <div class="feature-item">
                  <div class="feature-item-icon">📋</div>
                  <div class="feature-item-title">All Features</div>
                  <div class="feature-item-desc mb-3">See everything Tooda has to offer.</div>
                  <a href="/Tooda/features" class="cta-primary">📋 View Features →</a>
                </div>
              </div>
            </div>
          </section>

        </div>
      </div>

      <!-- ═══════════════════════ Navigation bar ═══════════════════════ -->
      <nav class="slide-nav" aria-label="Slide navigation">
        <div class="slide-nav-controls">
          <button id="btn-prev" class="nav-btn" aria-label="Previous slide" disabled>← Prev</button>

          <div class="flex flex-col items-center gap-2">
            <div class="progress-dots" id="progress-dots">
              <button class="dot active" aria-label="Go to slide 1"></button>
              <button class="dot" aria-label="Go to slide 2"></button>
              <button class="dot" aria-label="Go to slide 3"></button>
              <button class="dot" aria-label="Go to slide 4"></button>
              <button class="dot" aria-label="Go to slide 5"></button>
              <button class="dot" aria-label="Go to slide 6"></button>
            </div>
            <span class="slide-counter" id="slide-counter" aria-live="polite">1 / 6</span>
          </div>

          <button id="btn-next" class="nav-btn" aria-label="Next slide">Next →</button>
        </div>
      </nav>

    </div>

    <script>
      import Reveal from 'reveal.js';
      import 'reveal.js/dist/reveal.css';

      const revealEl = document.querySelector<HTMLElement>('.reveal');
      if (!revealEl) throw new Error('Reveal.js container (.reveal) not found in DOM');

      // Detect mobile landscape before initialising Reveal so the correct
      // center setting is baked in from the very first render.
      const mobileLandscapeQuery = window.matchMedia('(orientation: landscape) and (max-height: 500px)');

      const deck = new Reveal(revealEl, {
        embedded: true,
        hash: false,
        keyboard: false,
        touch: true,
        controls: false,
        progress: false,
        slideNumber: false,
        // In mobile landscape top-align content so it fills from the top;
        // in all other orientations centre it as usual.
        center: !mobileLandscapeQuery.matches,
        transition: 'slide',
        // Disable the responsive scroll-view that Reveal.js activates automatically
        // on narrow viewports (default threshold: 435 px).  In scroll-view mode every
        // section is wrapped in a .scroll-page div, so isLastSlide() incorrectly
        // returns true for slide 1 (no nextElementSibling), graying out the Next button.
        scrollActivationWidth: 0,
      });

      const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
      const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
      const counter = document.getElementById('slide-counter')!;
      const dots = [...document.querySelectorAll<Element>('#progress-dots .dot')];

      function updateUI(): void {
        const total = deck.getTotalSlides();
        const idx = deck.getIndices().h;
        counter.textContent = `${idx + 1} / ${total}`;
        btnPrev.disabled = deck.isFirstSlide();
        btnNext.disabled = deck.isLastSlide();
        dots.forEach((dot, i) => dot.classList.toggle('active', i === idx));
        history.replaceState(null, '', `#slide-${idx + 1}`);
      }

      deck.on('slidechanged', updateUI);

      // On ready: restore slide from URL hash first, then always sync the UI
      deck.on('ready', () => {
        const match = window.location.hash.match(/^#slide-(\d+)$/);
        if (match) {
          const idx = parseInt(match[1], 10) - 1;
          const total = deck.getTotalSlides();
          if (idx >= 0 && idx < total) {
            deck.slide(idx);
          }
        }
        updateUI();
      });

      btnPrev.addEventListener('click', () => { deck.prev(); });
      btnNext.addEventListener('click', () => { deck.next(); });
      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => { deck.slide(i); });
      });

      // ── Landscape slide alignment ─────────────────────────────────────────────
      // Re-apply the center setting whenever the device is rotated so that
      // switching between portrait and landscape is seamless.
      function updateSlideAlignment(mq: MediaQueryList | MediaQueryListEvent): void {
        deck.configure({ center: !mq.matches });
        deck.sync();
      }
      mobileLandscapeQuery.addEventListener('change', updateSlideAlignment);

      // Document-level keyboard navigation so arrow keys work regardless of focus
      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          e.preventDefault();
          deck.next();
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault();
          deck.prev();
        }
      });

      deck.initialize();

      // ── Theme toggle ──────────────────────────────────────────────────────────
      const themeBtn = document.getElementById('theme-toggle');
      if (themeBtn) {
        themeBtn.setAttribute('aria-label', document.documentElement.classList.contains('dark') ? 'Switch to light mode' : 'Switch to dark mode');
        themeBtn.addEventListener('click', function () {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          themeBtn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
        });
      }
    </script>
  </body>
</html>
