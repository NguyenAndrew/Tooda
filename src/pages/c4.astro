---
import ExcalidrawViewer from '../components/ExcalidrawViewer';
import HealthcarePlatform2D from '../components/HealthcarePlatform2D';
import HealthcarePlatform3D from '../components/HealthcarePlatform3D';
import {
  bankingLevel1Elements, bankingLevel2Elements, bankingLevel3Elements, bankingLevel4Elements,
  ecommerceLevel1Elements, ecommerceLevel2Elements, ecommerceLevel3Elements, ecommerceLevel4Elements,
  ridesharingLevel1Elements, ridesharingLevel2Elements, ridesharingLevel3Elements, ridesharingLevel4Elements,
  toodaLevel1Elements, toodaLevel2Elements, toodaLevel3Elements, toodaLevel4Elements,
  mermaidDiagrams,
  levelConnections,
} from '../data/c4/diagrams';
import { LEVEL_NODES as bankingNodes } from '../data/excalidraw/banking/nodes';
import { LEVEL_NODES as ecommerceNodes } from '../data/excalidraw/ecommerce/nodes';
import { LEVEL_NODES as ridesharingNodes } from '../data/excalidraw/ridesharing/nodes';
import { LEVEL_NODES as toodaNodes } from '../data/excalidraw/tooda/nodes';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <meta name="description" content="C4 Diagram Examples – Three systems illustrated across all 4 levels of the C4 model" />
    <title>C4 Diagrams | Tooda</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme = stored === 'light' ? 'light' : 'dark';
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg-color: #f8fafc;
        --grad1: rgba(20,184,166,0.15);
        --grad2: rgba(6,182,212,0.10);
        --grad3: rgba(16,185,129,0.07);
        --grid-line: rgba(20,184,166,0.04);
      }

      :root.dark {
        --bg-color: #0f172a;
        --grad1: rgba(20,184,166,0.28);
        --grad2: rgba(6,182,212,0.18);
        --grad3: rgba(16,185,129,0.14);
        --grid-line: rgba(20,184,166,0.08);
      }

      body {
        background-color: var(--bg-color);
        background-image:
          radial-gradient(ellipse 80% 60% at 50% -10%, var(--grad1) 0%, transparent 70%),
          radial-gradient(ellipse 50% 40% at 90% 80%, var(--grad2) 0%, transparent 60%),
          radial-gradient(ellipse 40% 40% at 10% 90%, var(--grad3) 0%, transparent 60%);
        @apply min-h-dvh font-sans text-slate-900 dark:text-slate-50;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--grid-line) 1px, transparent 1px),
          linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 0;
      }

      .page-content {
        position: relative;
        z-index: 1;
      }

      @keyframes glow-pulse {
        0%, 100% { filter: drop-shadow(0 0 16px rgba(20,184,166,0.5)); }
        50%       { filter: drop-shadow(0 0 36px rgba(6,182,212,0.8)); }
      }

      header {
        @apply px-4 pb-4 pt-8 text-center;
      }

      header h1 {
        animation: glow-pulse 3s ease-in-out infinite;
        @apply mb-2 bg-gradient-to-br from-teal-500 via-cyan-400 to-emerald-400 bg-clip-text text-[clamp(2rem,6vw,3.5rem)] font-extrabold text-transparent;
      }

      header p {
        @apply mb-3 text-base text-slate-500 dark:text-slate-400;
      }

      header .back-link {
        @apply inline-block text-[0.9rem] text-teal-600 no-underline dark:text-teal-400;
      }

      header .back-link:hover {
        @apply underline;
      }

      /* ── Controls panel: visually groups Example / Renderer / Level rows ── */
      .controls-panel {
        @apply mx-auto mb-8 max-w-[900px] overflow-hidden rounded-2xl border border-slate-200/70 bg-white/40 backdrop-blur-sm dark:border-slate-700/50 dark:bg-slate-800/30;
      }

      .controls-section {
        @apply px-4 py-4;
      }

      .controls-section + .controls-section {
        @apply border-t border-slate-200/60 dark:border-slate-700/40;
      }

      .controls-label {
        @apply mb-2 block text-center text-[0.65rem] font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500;
      }

      .export-area {
        @apply mt-3 flex justify-center;
      }

      .examples {
        @apply flex flex-wrap justify-center gap-2;
      }

      .example-btn {
        @apply inline-block cursor-pointer rounded-lg border border-slate-300 bg-slate-100 px-5 py-2 text-[0.95rem] text-slate-600 no-underline transition-all duration-200 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400;
      }

      .example-btn:hover {
        @apply bg-slate-200 text-slate-900 dark:bg-slate-700 dark:text-slate-50;
      }

      .example-btn.active {
        @apply border-transparent bg-gradient-to-br from-teal-500 to-cyan-500 text-white;
      }

      .tabs {
        @apply flex flex-wrap justify-center gap-2;
      }

      .tab-btn {
        @apply inline-block cursor-pointer rounded-lg border border-slate-300 bg-slate-100 px-5 py-2 text-[0.95rem] text-slate-600 no-underline transition-all duration-200 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400;
      }

      .tab-btn:hover {
        @apply bg-slate-200 text-slate-900 dark:bg-slate-700 dark:text-slate-50;
      }

      .tab-btn.active {
        @apply border-transparent bg-gradient-to-br from-teal-500 to-cyan-500 text-white;
      }

      .tab-panel {
        @apply mx-auto hidden max-w-[900px] px-4 pb-12;
      }

      .tab-panel.active {
        @apply block;
      }

      .tab-panel h2 {
        @apply mb-2 text-2xl font-bold text-slate-700 dark:text-slate-200;
      }

      .tab-panel .description {
        @apply mb-6 text-[0.95rem] leading-relaxed text-slate-500 dark:text-slate-400;
      }

      .excalidraw-wrapper {
        @apply overflow-hidden rounded-xl;
        height: 600px;
      }

      .mermaid-wrapper {
        @apply hidden overflow-hidden rounded-xl bg-white p-6;
      }

      .mermaid-wrapper .mermaid {
        @apply flex justify-center;
      }

      .threeD-wrapper {
        @apply hidden overflow-hidden rounded-xl;
      }

      .twoD-wrapper {
        @apply hidden overflow-hidden rounded-xl bg-slate-900;
      }

      .renderer-toggle {
        @apply flex flex-wrap justify-center gap-2;
      }

      .renderer-btn {
        @apply inline-block cursor-pointer rounded-lg border border-slate-300 bg-slate-100 px-5 py-2 text-[0.95rem] text-slate-600 no-underline transition-all duration-200 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400;
      }

      .renderer-btn:hover {
        @apply bg-slate-200 text-slate-900 dark:bg-slate-700 dark:text-slate-50;
      }

      .renderer-btn.active {
        @apply border-transparent bg-gradient-to-br from-teal-500 to-cyan-500 text-white;
      }

      .export-png-btn {
        @apply inline-block cursor-pointer rounded-lg border border-slate-300 bg-slate-100 px-5 py-2 text-[0.95rem] text-slate-600 no-underline transition-all duration-200 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400;
      }

      .export-png-btn:hover {
        @apply bg-slate-200 text-slate-900 dark:bg-slate-700 dark:text-slate-50;
      }

      /* Theme toggle button */
      .theme-toggle-btn {
        @apply fixed right-4 top-4 z-50 flex h-10 w-10 items-center justify-center rounded-full border border-slate-300 bg-white/80 text-slate-600 shadow-md backdrop-blur-sm transition-all duration-200 hover:border-teal-400 hover:text-slate-900 dark:border-slate-700 dark:bg-slate-800/80 dark:text-slate-300 dark:hover:border-teal-500/50 dark:hover:text-slate-50;
      }
    </style>
  </head>
  <body>
    <!-- Theme toggle button -->
    <button id="theme-toggle" type="button" aria-label="Switch to light mode" class="theme-toggle-btn">
      <svg class="hidden size-5 dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="block size-5 dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <div class="page-content">
    <header>
      <h1>C4 Diagram Examples</h1>
      <p>Four systems illustrated across all 4 levels of the C4 model</p>
      <a href="/Tooda/" class="back-link">← Back to Home</a>
    </header>

    <div class="controls-panel">
      <div class="controls-section">
        <span class="controls-label">Example</span>
        <div class="examples">
          <a href="/Tooda/c4?example=banking" class="example-btn active" data-example="banking">Online Banking</a>
          <a href="/Tooda/c4?example=ecommerce" class="example-btn" data-example="ecommerce">E-Commerce</a>
          <a href="/Tooda/c4?example=ridesharing" class="example-btn" data-example="ridesharing">Ride-Sharing</a>
          <a href="/Tooda/c4?example=tooda" class="example-btn" data-example="tooda">Tooda</a>
        </div>
      </div>

      <div class="controls-section">
        <span class="controls-label">Renderer</span>
        <div class="renderer-toggle">
          <a href="?renderer=excalidraw" class="renderer-btn active" data-renderer="excalidraw">&#9999;&#65039; Excalidraw</a>
          <a href="?renderer=mermaid" class="renderer-btn" data-renderer="mermaid">&#128202; Mermaid</a>
          <a href="?renderer=2d" class="renderer-btn" data-renderer="2d">&#128506;&#65039; 2D</a>
          <a href="?renderer=3d" class="renderer-btn" data-renderer="3d">&#127922; 3D</a>
        </div>
      </div>

      <div class="controls-section">
        <span class="controls-label">Level</span>
        <div class="tabs">
          <a href="#level1" class="tab-btn active" data-tab="level1">Level 1 – Context</a>
          <a href="#level2" class="tab-btn" data-tab="level2">Level 2 – Container</a>
          <a href="#level3" class="tab-btn" data-tab="level3">Level 3 – Component</a>
          <a href="#level4" class="tab-btn" data-tab="level4">Level 4 – Code</a>
        </div>
        <div class="export-area">
          <a
            id="export-png-btn"
            href="/Tooda/api/c4/banking/level1.png"
            download="c4-banking-level1.png"
            class="export-png-btn"
            data-testid="export-png-btn"
          >&#128247; Export PNG</a>
        </div>
      </div>
    </div>

    <!-- Level 1: System Context -->
    <section id="level1" class="tab-panel active">
      <p class="description">
        Shows the system in context: who uses it and which external systems it
        interacts with.
      </p>
      <div class="example-content" data-example="banking">
        <div class="excalidraw-view excalidraw-wrapper" data-example="banking">
          <ExcalidrawViewer client:only="react" elements={bankingLevel1Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.banking.level1}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={bankingNodes[1]} connections={levelConnections.banking.level1} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={bankingNodes[1]} connections={levelConnections.banking.level1} />
        </div>
      </div>
      <div class="example-content" data-example="ecommerce" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="ecommerce">
          <ExcalidrawViewer client:only="react" elements={ecommerceLevel1Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.ecommerce.level1}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={ecommerceNodes[1]} connections={levelConnections.ecommerce.level1} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={ecommerceNodes[1]} connections={levelConnections.ecommerce.level1} />
        </div>
      </div>
      <div class="example-content" data-example="ridesharing" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="ridesharing">
          <ExcalidrawViewer client:only="react" elements={ridesharingLevel1Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.ridesharing.level1}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={ridesharingNodes[1]} connections={levelConnections.ridesharing.level1} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={ridesharingNodes[1]} connections={levelConnections.ridesharing.level1} />
        </div>
      </div>
      <div class="example-content" data-example="tooda" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="tooda">
          <ExcalidrawViewer client:only="react" elements={toodaLevel1Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.tooda.level1}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={toodaNodes[1]} connections={levelConnections.tooda.level1} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={toodaNodes[1]} connections={levelConnections.tooda.level1} />
        </div>
      </div>
    </section>

    <!-- Level 2: Container -->
    <section id="level2" class="tab-panel">
      <p class="description">
        Zooms in on the system to show the containers (applications and data
        stores) that make it up.
      </p>
      <div class="example-content" data-example="banking">
        <div class="excalidraw-view excalidraw-wrapper" data-example="banking">
          <ExcalidrawViewer client:only="react" elements={bankingLevel2Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.banking.level2}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={bankingNodes[2]} connections={levelConnections.banking.level2} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={bankingNodes[2]} connections={levelConnections.banking.level2} />
        </div>
      </div>
      <div class="example-content" data-example="ecommerce" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="ecommerce">
          <ExcalidrawViewer client:only="react" elements={ecommerceLevel2Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.ecommerce.level2}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={ecommerceNodes[2]} connections={levelConnections.ecommerce.level2} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={ecommerceNodes[2]} connections={levelConnections.ecommerce.level2} />
        </div>
      </div>
      <div class="example-content" data-example="ridesharing" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="ridesharing">
          <ExcalidrawViewer client:only="react" elements={ridesharingLevel2Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.ridesharing.level2}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={ridesharingNodes[2]} connections={levelConnections.ridesharing.level2} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={ridesharingNodes[2]} connections={levelConnections.ridesharing.level2} />
        </div>
      </div>
      <div class="example-content" data-example="tooda" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="tooda">
          <ExcalidrawViewer client:only="react" elements={toodaLevel2Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.tooda.level2}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={toodaNodes[2]} connections={levelConnections.tooda.level2} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={toodaNodes[2]} connections={levelConnections.tooda.level2} />
        </div>
      </div>
    </section>

    <!-- Level 3: Component -->
    <section id="level3" class="tab-panel">
      <p class="description">
        Zooms in on a key container to show the components (services and
        controllers) inside it.
      </p>
      <div class="example-content" data-example="banking">
        <div class="excalidraw-view excalidraw-wrapper" data-example="banking">
          <ExcalidrawViewer client:only="react" elements={bankingLevel3Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.banking.level3}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={bankingNodes[3]} connections={levelConnections.banking.level3} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={bankingNodes[3]} connections={levelConnections.banking.level3} />
        </div>
      </div>
      <div class="example-content" data-example="ecommerce" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="ecommerce">
          <ExcalidrawViewer client:only="react" elements={ecommerceLevel3Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.ecommerce.level3}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={ecommerceNodes[3]} connections={levelConnections.ecommerce.level3} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={ecommerceNodes[3]} connections={levelConnections.ecommerce.level3} />
        </div>
      </div>
      <div class="example-content" data-example="ridesharing" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="ridesharing">
          <ExcalidrawViewer client:only="react" elements={ridesharingLevel3Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.ridesharing.level3}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={ridesharingNodes[3]} connections={levelConnections.ridesharing.level3} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={ridesharingNodes[3]} connections={levelConnections.ridesharing.level3} />
        </div>
      </div>
      <div class="example-content" data-example="tooda" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="tooda">
          <ExcalidrawViewer client:only="react" elements={toodaLevel3Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.tooda.level3}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={toodaNodes[3]} connections={levelConnections.tooda.level3} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={toodaNodes[3]} connections={levelConnections.tooda.level3} />
        </div>
      </div>
    </section>

    <!-- Level 4: Code -->
    <section id="level4" class="tab-panel">
      <p class="description">
        Zooms in on a key component to show the classes and interfaces that
        implement it.
      </p>
      <div class="example-content" data-example="banking">
        <div class="excalidraw-view excalidraw-wrapper" data-example="banking">
          <ExcalidrawViewer client:only="react" elements={bankingLevel4Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.banking.level4}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={bankingNodes[4]} connections={levelConnections.banking.level4} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={bankingNodes[4]} connections={levelConnections.banking.level4} />
        </div>
      </div>
      <div class="example-content" data-example="ecommerce" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="ecommerce">
          <ExcalidrawViewer client:only="react" elements={ecommerceLevel4Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.ecommerce.level4}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={ecommerceNodes[4]} connections={levelConnections.ecommerce.level4} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={ecommerceNodes[4]} connections={levelConnections.ecommerce.level4} />
        </div>
      </div>
      <div class="example-content" data-example="ridesharing" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="ridesharing">
          <ExcalidrawViewer client:only="react" elements={ridesharingLevel4Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.ridesharing.level4}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={ridesharingNodes[4]} connections={levelConnections.ridesharing.level4} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={ridesharingNodes[4]} connections={levelConnections.ridesharing.level4} />
        </div>
      </div>
      <div class="example-content" data-example="tooda" style="display:none">
        <div class="excalidraw-view excalidraw-wrapper" data-example="tooda">
          <ExcalidrawViewer client:only="react" elements={toodaLevel4Elements} />
        </div>
        <div class="mermaid-view mermaid-wrapper">
          <div class="mermaid" set:text={mermaidDiagrams.tooda.level4}></div>
        </div>
        <div class="twoD-view twoD-wrapper">
          <HealthcarePlatform2D client:only="react" nodes={toodaNodes[4]} connections={levelConnections.tooda.level4} />
        </div>
        <div class="threeD-view threeD-wrapper">
          <HealthcarePlatform3D client:only="react" nodes={toodaNodes[4]} connections={levelConnections.tooda.level4} />
        </div>
      </div>
    </section>
    <script src="/Tooda/mermaid.min.js" is:inline></script>
    <script type="module">
      const { default: elkLayouts } = await import('/Tooda/mermaid-layout-elk.esm.min.mjs');
      mermaid.registerLayoutLoaders(elkLayouts);
      window._resolveElk();
    </script>
    <script is:inline>
      // ELK layout engine is loaded asynchronously; all mermaid.run() calls wait for it.
      window._elkReady = new Promise(resolve => { window._resolveElk = resolve; });

      mermaid.initialize({ startOnLoad: false, theme: 'default' });

      let currentExample = 'banking';
      let currentTab = 'level1';
      let currentRenderer = 'excalidraw';

      const validTabs = ['level1', 'level2', 'level3', 'level4'];
      const validExamples = ['banking', 'ecommerce', 'ridesharing', 'tooda'];

      // ---- Mermaid rendering helper ----
      function renderMermaidInContent(content) {
        const unrendered = Array.from(content.querySelectorAll('.mermaid')).filter(
          function (el) { return !el.querySelector('svg'); }
        );
        if (unrendered.length > 0) {
          unrendered.forEach(function (el) { el.removeAttribute('data-processed'); });
          window._elkReady.then(function () { mermaid.run({ nodes: unrendered }); });
        }
      }

      // ---- Renderer toggle ----
      const rendererBtns = document.querySelectorAll('.renderer-btn');

      function activateRenderer(renderer) {
        if (renderer !== 'excalidraw' && renderer !== 'mermaid' && renderer !== '2d' && renderer !== '3d') renderer = 'excalidraw';
        currentRenderer = renderer;

        rendererBtns.forEach(function (b) { b.classList.remove('active'); });
        const activeBtn = document.querySelector('.renderer-btn[data-renderer="' + renderer + '"]');
        if (activeBtn) activeBtn.classList.add('active');

        document.querySelectorAll('.excalidraw-view').forEach(function (el) { el.style.display = 'none'; });
        document.querySelectorAll('.mermaid-view').forEach(function (el) { el.style.display = 'none'; });
        document.querySelectorAll('.twoD-view').forEach(function (el) { el.style.display = 'none'; });
        document.querySelectorAll('.threeD-view').forEach(function (el) { el.style.display = 'none'; });

        if (renderer === 'excalidraw') {
          document.querySelectorAll('.excalidraw-view').forEach(function (el) { el.style.display = ''; });
        } else if (renderer === 'mermaid') {
          document.querySelectorAll('.mermaid-view').forEach(function (el) { el.style.display = 'block'; });

          // Render any un-rendered Mermaid diagrams in the active panel / example
          const activePanel = document.querySelector('.tab-panel.active');
          if (activePanel) {
            const activeContent = activePanel.querySelector('.example-content[data-example="' + currentExample + '"]');
            if (activeContent) renderMermaidInContent(activeContent);
          }
        } else if (renderer === '2d') {
          document.querySelectorAll('.twoD-view').forEach(function (el) { el.style.display = 'block'; });
        } else {
          document.querySelectorAll('.threeD-view').forEach(function (el) { el.style.display = 'block'; });
        }

        updateExportPngBtn();
      }

      rendererBtns.forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          const renderer = btn.dataset.renderer;
          const url = new URL(window.location.href);
          url.searchParams.set('renderer', renderer);
          history.pushState(null, '', url.toString());
          activateRenderer(renderer);
        });
      });

      // ---- Tab switching ----
      const tabButtons = document.querySelectorAll('.tab-btn');
      const tabPanels = document.querySelectorAll('.tab-panel');

      function updateExampleVisibility(panel) {
        panel.querySelectorAll('.example-content').forEach(function (w) {
          w.style.display = (w.dataset.example === currentExample) ? '' : 'none';
        });
      }

      function updateExportPngBtn() {
        const container = document.getElementById('export-png-container');
        if (!container) return;
        if (currentRenderer === '3d') {
          container.style.display = 'none';
          return;
        }
        container.style.display = '';
        const btn = document.getElementById('export-png-btn');
        if (!btn) return;
        const href = `/Tooda/api/c4/${currentExample}/${currentTab}.png`;
        btn.setAttribute('href', href);
        btn.setAttribute('download', `c4-${currentExample}-${currentTab}.png`);
      }

      function activateTab(target) {
        if (!validTabs.includes(target)) target = 'level1';
        currentTab = target;

        tabButtons.forEach(function (b) { b.classList.remove('active'); });
        tabPanels.forEach(function (p) { p.classList.remove('active'); });

        const activeBtn = document.querySelector('.tab-btn[data-tab="' + target + '"]');
        if (activeBtn) activeBtn.classList.add('active');

        const panel = document.getElementById(target);
        if (panel) {
          panel.classList.add('active');
          updateExampleVisibility(panel);

          // Render Mermaid diagrams when switching tabs in Mermaid mode
          if (currentRenderer === 'mermaid') {
            const activeContent = panel.querySelector('.example-content[data-example="' + currentExample + '"]');
            if (activeContent) renderMermaidInContent(activeContent);
          }
        }
        updateExportPngBtn();
      }

      tabButtons.forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          const target = btn.dataset.tab;
          history.pushState(null, '', '#' + target);
          activateTab(target);
        });
      });

      function activateFromHash() {
        const hash = window.location.hash.slice(1) || 'level1';
        activateTab(hash);
      }

      window.addEventListener('hashchange', activateFromHash);

      // ---- Example switching ----
      const exampleBtns = document.querySelectorAll('.example-btn');

      function activateExample(key) {
        if (!validExamples.includes(key)) key = 'banking';
        currentExample = key;

        exampleBtns.forEach(function (b) { b.classList.remove('active'); });
        const activeBtn = document.querySelector('.example-btn[data-example="' + key + '"]');
        if (activeBtn) activeBtn.classList.add('active');

        document.querySelectorAll('.tab-panel').forEach(function (panel) {
          updateExampleVisibility(panel);
        });

        // Render Mermaid diagrams for the newly selected example if in Mermaid mode
        if (currentRenderer === 'mermaid') {
          const activePanel = document.querySelector('.tab-panel.active');
          if (activePanel) {
            const activeContent = activePanel.querySelector('.example-content[data-example="' + key + '"]');
            if (activeContent) renderMermaidInContent(activeContent);
          }
        }
        updateExportPngBtn();
      }

      exampleBtns.forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          const key = btn.dataset.example;
          const url = new URL(window.location.href);
          url.searchParams.set('example', key);
          history.pushState(null, '', url.toString());
          activateExample(key);
        });
      });

      // ---- Initialize from URL params ----
      function init() {
        const params = new URLSearchParams(window.location.search);
        const example = params.get('example') || 'banking';
        const renderer = params.get('renderer') || 'excalidraw';
        activateExample(example);
        activateRenderer(renderer);
        activateFromHash();
      }

      window.addEventListener('popstate', init);
      init();
    </script>
    </div>
    <script>
      const btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.setAttribute('aria-label', document.documentElement.classList.contains('dark') ? 'Switch to light mode' : 'Switch to dark mode');
        btn.addEventListener('click', function () {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
        });
      }
    </script>
  </body>
</html>
