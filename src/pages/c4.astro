---
import ExcalidrawViewer from '../components/ExcalidrawViewer';
import C4Diagram2D from '../components/C4Diagram2D';
import C4Diagram3D from '../components/C4Diagram3D';
import { diagrams } from '../data/c4/diagrams';

// All data needed for rendering is derived from the diagrams catalog.
// To add a new diagram, add an entry to src/data/c4/diagrams.ts – no
// changes to this page are required.

const levels = [
  { id: 'level1', label: 'Level 1 – Context',   num: 1, description: 'Shows the system in context: who uses it and which external systems it interacts with.' },
  { id: 'level2', label: 'Level 2 – Container', num: 2, description: 'Zooms in on the system to show the containers (applications and data stores) that make it up.' },
  { id: 'level3', label: 'Level 3 – Component', num: 3, description: 'Zooms in on a key container to show the components (services and controllers) inside it.' },
  { id: 'level4', label: 'Level 4 – Code',      num: 4, description: 'Zooms in on a key component to show the classes and interfaces that implement it.' },
] as const;

const exampleEntries = Object.entries(diagrams);
const exampleKeys = Object.keys(diagrams);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <meta name="description" content="C4 Diagram Examples – Three systems illustrated across all 4 levels of the C4 model" />
    <title>C4 Diagrams | Tooda</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme = stored === 'light' ? 'light' : 'dark';
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg-color: #f8fafc;
        --grad1: rgba(20,184,166,0.15);
        --grad2: rgba(6,182,212,0.10);
        --grad3: rgba(16,185,129,0.07);
        --grid-line: rgba(20,184,166,0.04);
      }

      :root.dark {
        --bg-color: #0f172a;
        --grad1: rgba(20,184,166,0.28);
        --grad2: rgba(6,182,212,0.18);
        --grad3: rgba(16,185,129,0.14);
        --grid-line: rgba(20,184,166,0.08);
      }

      body {
        background-color: var(--bg-color);
        background-image:
          radial-gradient(ellipse 80% 60% at 50% -10%, var(--grad1) 0%, transparent 70%),
          radial-gradient(ellipse 50% 40% at 90% 80%, var(--grad2) 0%, transparent 60%),
          radial-gradient(ellipse 40% 40% at 10% 90%, var(--grad3) 0%, transparent 60%);
        @apply min-h-dvh font-sans text-slate-900 dark:text-slate-50;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--grid-line) 1px, transparent 1px),
          linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 0;
      }

      .page-content {
        position: relative;
        z-index: 1;
      }

      @keyframes glow-pulse {
        0%, 100% { filter: drop-shadow(0 0 16px rgba(20,184,166,0.5)); }
        50%       { filter: drop-shadow(0 0 36px rgba(6,182,212,0.8)); }
      }

      header {
        @apply px-4 pb-4 pt-8 text-center;
      }

      header h1 {
        animation: glow-pulse 3s ease-in-out infinite;
        @apply mb-2 bg-gradient-to-br from-teal-500 via-cyan-400 to-emerald-400 bg-clip-text text-[clamp(2rem,6vw,3.5rem)] font-extrabold text-transparent;
      }

      header p {
        @apply mb-3 text-base text-slate-500 dark:text-slate-400;
      }

      header .back-link {
        @apply inline-block text-[0.9rem] text-teal-600 no-underline dark:text-teal-400;
      }

      header .back-link:hover {
        @apply underline;
      }

      /* ── Controls panel: visually groups Example / Renderer / Level rows ── */
      .controls-panel {
        @apply mx-auto mb-8 max-w-[900px] overflow-hidden rounded-2xl border border-slate-200/70 bg-white/40 backdrop-blur-sm dark:border-slate-700/50 dark:bg-slate-800/30;
        box-shadow: 0 4px 24px rgba(20,184,166,0.06), 0 1px 4px rgba(0,0,0,0.04);
      }

      .controls-section {
        @apply px-4 py-4;
      }

      .controls-section + .controls-section {
        @apply border-t border-slate-200/60 dark:border-slate-700/40;
      }

      .controls-label {
        @apply mb-2 block text-center text-[0.65rem] font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500;
      }

      .export-area {
        @apply mt-3 flex justify-center;
      }

      .examples {
        @apply flex flex-wrap justify-center gap-2;
      }

      /* ── Shared pill button base (example / renderer / tab) ── */
      .example-btn,
      .tab-btn,
      .renderer-btn,
      .export-png-btn {
        position: relative;
        overflow: hidden;
        @apply inline-block cursor-pointer rounded-full border border-slate-300/80 bg-white/60 px-5 py-2 text-[0.9rem] font-medium text-slate-600 no-underline backdrop-blur-sm transition-all duration-200 dark:border-slate-700/80 dark:bg-slate-800/60 dark:text-slate-400;
      }

      .example-btn:hover,
      .tab-btn:hover,
      .renderer-btn:hover,
      .export-png-btn:hover {
        @apply border-teal-400/60 text-slate-900 dark:border-teal-500/60 dark:text-slate-50;
        transform: translateY(-1px);
        box-shadow: 0 3px 10px rgba(20,184,166,0.12), 0 1px 3px rgba(0,0,0,0.05);
      }

      /* ── Active state: gradient pill with subtle glow ── */
      @keyframes active-glow-pulse {
        0%, 100% {
          box-shadow:
            0 0 6px  rgba(20,184,166,0.4),
            0 0 14px rgba(20,184,166,0.2),
            inset 0 1px 0 rgba(255,255,255,0.2);
        }
        50% {
          box-shadow:
            0 0 10px rgba(20,184,166,0.55),
            0 0 22px rgba(6,182,212,0.25),
            inset 0 1px 0 rgba(255,255,255,0.2);
        }
      }

      .example-btn.active,
      .tab-btn.active,
      .renderer-btn.active {
        border-color: transparent;
        background: linear-gradient(135deg, #14b8a6, #06b6d4, #10b981);
        color: #fff;
        font-weight: 600;
        box-shadow:
          0 0 6px  rgba(20,184,166,0.4),
          0 0 14px rgba(20,184,166,0.2),
          inset 0 1px 0 rgba(255,255,255,0.2);
      }

      @media (prefers-reduced-motion: no-preference) {
        .example-btn.active,
        .tab-btn.active,
        .renderer-btn.active {
          animation: active-glow-pulse 3s ease-in-out infinite;
        }
      }

      .tabs {
        @apply flex flex-wrap justify-center gap-2;
      }

      .tab-panel {
        @apply mx-auto hidden max-w-[900px] px-4 pb-12;
      }

      .tab-panel.active {
        @apply block;
        animation: panel-enter 0.25s ease forwards;
      }

      @keyframes panel-enter {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @media (prefers-reduced-motion: reduce) {
        .tab-panel.active {
          animation: none;
        }
      }

      .tab-panel h2 {
        @apply mb-2 text-2xl font-bold text-slate-700 dark:text-slate-200;
      }

      .tab-panel .description {
        @apply mb-6 text-[0.95rem] leading-relaxed text-slate-500 dark:text-slate-400;
      }

      .excalidraw-wrapper {
        @apply overflow-hidden rounded-xl;
        height: 600px;
      }

      .mermaid-wrapper {
        @apply hidden overflow-hidden rounded-xl bg-white p-6;
      }

      .mermaid-wrapper .mermaid {
        @apply flex justify-center;
      }

      .threeD-wrapper {
        @apply hidden overflow-hidden rounded-xl;
      }

      .twoD-wrapper {
        @apply hidden overflow-hidden rounded-xl bg-slate-900;
      }

      .renderer-toggle {
        @apply flex flex-wrap justify-center gap-2;
      }

      /* Theme toggle button */
      .theme-toggle-btn {
        @apply fixed right-4 top-4 z-50 flex h-10 w-10 items-center justify-center rounded-full border border-slate-300 bg-white/80 text-slate-600 shadow-md backdrop-blur-sm transition-all duration-200 dark:border-slate-700 dark:bg-slate-800/80 dark:text-slate-300;
      }

      @media (hover: hover) {
        .theme-toggle-btn:hover {
          border-color: rgba(20,184,166,0.6);
          box-shadow: 0 0 12px rgba(20,184,166,0.3), 0 2px 8px rgba(0,0,0,0.1);
          transform: rotate(10deg) scale(1.05);
        }
      }
    </style>
  </head>
  <body>
    <!-- Theme toggle button -->
    <button id="theme-toggle" type="button" aria-label="Switch to light mode" class="theme-toggle-btn">
      <svg class="hidden size-5 dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="block size-5 dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <div class="page-content">
    <!-- Catalog metadata used by the inline script to build validExamples -->
    <div id="examples-catalog" data-keys={JSON.stringify(exampleKeys)} style="display:none" aria-hidden="true"></div>
    <header>
      <h1>C4 Diagram Examples</h1>
      <p>{exampleKeys.length} {exampleKeys.length === 1 ? 'system' : 'systems'} illustrated across all 4 levels of the C4 model</p>
      <a href="/Tooda/" class="back-link">← Back to Home</a>
    </header>

    <div class="controls-panel">
      <div class="controls-section">
        <span class="controls-label">Example</span>
        <div class="examples">
          {exampleEntries.map(([key, diagram], i) => (
            <a href={`/Tooda/c4?example=${key}`} class={`example-btn${i === 0 ? ' active' : ''}`} data-example={key}>{diagram.shortTitle}</a>
          ))}
        </div>
      </div>

      <div class="controls-section">
        <span class="controls-label">Renderer</span>
        <div class="renderer-toggle">
          <a href="?renderer=excalidraw" class="renderer-btn active" data-renderer="excalidraw">&#9999;&#65039; Excalidraw</a>
          <a href="?renderer=mermaid" class="renderer-btn" data-renderer="mermaid">&#128202; Mermaid</a>
          <a href="?renderer=2d" class="renderer-btn" data-renderer="2d">&#128506;&#65039; 2D</a>
          <a href="?renderer=3d" class="renderer-btn" data-renderer="3d">&#127922; 3D</a>
        </div>
      </div>

      <div class="controls-section">
        <span class="controls-label">Level</span>
        <div class="tabs">
          {levels.map((level, i) => (
            <a href={`#${level.id}`} class={`tab-btn${i === 0 ? ' active' : ''}`} data-tab={level.id}>{level.label}</a>
          ))}
        </div>
        <div class="export-area">
          <button
            id="export-png-btn"
            class="export-png-btn"
            data-testid="export-png-btn"
          >&#128247; Export PNG</button>
        </div>
      </div>
    </div>

    <!-- Level sections (generated from catalog) -->
    {levels.map((level, levelIdx) => (
      <section id={level.id} class={`tab-panel${levelIdx === 0 ? ' active' : ''}`}>
        <p class="description">{level.description}</p>
        {exampleEntries.map(([key, diagram], i) => (
          <div class="example-content" data-example={key} style={i > 0 ? "display:none" : ""}>
            <div class="excalidraw-view excalidraw-wrapper" data-example={key}>
              <ExcalidrawViewer client:only="react" elements={diagram[level.id]} registrationKey={`${key}-${level.id}`} />
            </div>
            <div class="mermaid-view mermaid-wrapper">
              <div class="mermaid" set:text={diagram.mermaid[level.id]}></div>
            </div>
            <div class="twoD-view twoD-wrapper">
              <C4Diagram2D client:only="react" nodes={diagram.nodes[level.num]} connections={diagram.connections[level.id]} />
            </div>
            <div class="threeD-view threeD-wrapper">
              <C4Diagram3D client:only="react" nodes={diagram.nodes[level.num]} connections={diagram.connections[level.id]} />
            </div>
          </div>
        ))}
      </section>
    ))}
    <script src="/Tooda/mermaid.min.js" is:inline></script>
    <script type="module">
      const { default: elkLayouts } = await import('/Tooda/mermaid-layout-elk.esm.min.mjs');
      mermaid.registerLayoutLoaders(elkLayouts);
      window._resolveElk();
    </script>
    <script is:inline>
      // ELK layout engine is loaded asynchronously; all mermaid.run() calls wait for it.
      window._elkReady = new Promise(resolve => { window._resolveElk = resolve; });

      mermaid.initialize({ startOnLoad: false, theme: 'default' });

      let currentExample = 'banking';
      let currentTab = 'level1';
      let currentRenderer = 'excalidraw';

      const validTabs = ['level1', 'level2', 'level3', 'level4'];
      const validExamples = JSON.parse(document.getElementById('examples-catalog').dataset.keys);

      // ---- Mermaid rendering helper ----
      function renderMermaidInContent(content) {
        const unrendered = Array.from(content.querySelectorAll('.mermaid')).filter(
          function (el) { return !el.querySelector('svg'); }
        );
        if (unrendered.length > 0) {
          unrendered.forEach(function (el) { el.removeAttribute('data-processed'); });
          window._elkReady.then(function () { mermaid.run({ nodes: unrendered }); });
        }
      }

      // ---- Renderer toggle ----
      const rendererBtns = document.querySelectorAll('.renderer-btn');

      function activateRenderer(renderer) {
        if (renderer !== 'excalidraw' && renderer !== 'mermaid' && renderer !== '2d' && renderer !== '3d') renderer = 'excalidraw';
        currentRenderer = renderer;

        rendererBtns.forEach(function (b) { b.classList.remove('active'); });
        const activeBtn = document.querySelector('.renderer-btn[data-renderer="' + renderer + '"]');
        if (activeBtn) activeBtn.classList.add('active');

        document.querySelectorAll('.excalidraw-view').forEach(function (el) { el.style.display = 'none'; });
        document.querySelectorAll('.mermaid-view').forEach(function (el) { el.style.display = 'none'; });
        document.querySelectorAll('.twoD-view').forEach(function (el) { el.style.display = 'none'; });
        document.querySelectorAll('.threeD-view').forEach(function (el) { el.style.display = 'none'; });

        if (renderer === 'excalidraw') {
          document.querySelectorAll('.excalidraw-view').forEach(function (el) { el.style.display = ''; });
        } else if (renderer === 'mermaid') {
          document.querySelectorAll('.mermaid-view').forEach(function (el) { el.style.display = 'block'; });

          // Render any un-rendered Mermaid diagrams in the active panel / example
          const activePanel = document.querySelector('.tab-panel.active');
          if (activePanel) {
            const activeContent = activePanel.querySelector('.example-content[data-example="' + currentExample + '"]');
            if (activeContent) renderMermaidInContent(activeContent);
          }
        } else if (renderer === '2d') {
          document.querySelectorAll('.twoD-view').forEach(function (el) { el.style.display = 'block'; });
        } else {
          document.querySelectorAll('.threeD-view').forEach(function (el) { el.style.display = 'block'; });
        }

        updateExportPngBtn();
      }

      rendererBtns.forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          const renderer = btn.dataset.renderer;
          const url = new URL(window.location.href);
          url.searchParams.set('renderer', renderer);
          history.pushState(null, '', url.toString());
          activateRenderer(renderer);
        });
      });

      // ---- Tab switching ----
      const tabButtons = document.querySelectorAll('.tab-btn');
      const tabPanels = document.querySelectorAll('.tab-panel');

      function updateExampleVisibility(panel) {
        panel.querySelectorAll('.example-content').forEach(function (w) {
          w.style.display = (w.dataset.example === currentExample) ? '' : 'none';
        });
      }

      function updateExportPngBtn() {
        const container = document.getElementById('export-png-container');
        if (!container) return;
        if (currentRenderer === '3d') {
          container.style.display = 'none';
          return;
        }
        container.style.display = '';
      }

      async function svgToPngBlobUrl(svgEl) {
        const svgRect = svgEl.getBoundingClientRect();
        const svgW = svgRect.width || 800;
        const svgH = svgRect.height || 600;

        const vb = svgEl.getAttribute('viewBox');
        let vbW = svgW, vbH = svgH;
        if (vb) {
          const parts = vb.trim().split(/[\s,]+/).map(Number);
          if (parts.length === 4) { vbW = parts[2]; vbH = parts[3]; }
        }
        const scaleX = svgW > 0 ? vbW / svgW : 1;
        const scaleY = svgH > 0 ? vbH / svgH : 1;

        const liveFos = Array.from(svgEl.querySelectorAll('foreignObject'));
        const foData = liveFos.map(fo => {
          const r = fo.getBoundingClientRect();
          return {
            x: (r.left - svgRect.left) * scaleX,
            y: (r.top - svgRect.top) * scaleY,
            w: r.width * scaleX,
            h: r.height * scaleY,
            text: fo.textContent.trim(),
          };
        });

        const clone = svgEl.cloneNode(true);
        clone.setAttribute('width', String(Math.ceil(svgW)));
        clone.setAttribute('height', String(Math.ceil(svgH)));

        Array.from(clone.querySelectorAll('foreignObject')).forEach((fo, i) => {
          const d = foData[i];
          if (d && d.text) {
            const t = document.createElementNS('http://www.w3.org/2000/svg', 'text');
            t.setAttribute('x', String(d.x + d.w / 2));
            t.setAttribute('y', String(d.y + d.h / 2));
            t.setAttribute('text-anchor', 'middle');
            t.setAttribute('dominant-baseline', 'middle');
            t.setAttribute('fill', '#333');
            t.setAttribute('font-family', '"trebuchet ms",verdana,arial,sans-serif');
            t.setAttribute('font-size', '14');
            t.textContent = d.text;
            fo.parentNode.replaceChild(t, fo);
          } else {
            fo.remove();
          }
        });

        const svgData = new XMLSerializer().serializeToString(clone);
        const svgBlob = new Blob([svgData], { type: 'image/svg+xml;charset=utf-8' });
        const svgBlobUrl = URL.createObjectURL(svgBlob);
        return new Promise((resolve, reject) => {
          const img = new Image();
          img.onload = () => {
            URL.revokeObjectURL(svgBlobUrl);
            const canvas = document.createElement('canvas');
            canvas.width = img.naturalWidth || Math.ceil(svgW);
            canvas.height = img.naturalHeight || Math.ceil(svgH);
            const ctx = canvas.getContext('2d');
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.drawImage(img, 0, 0);
            canvas.toBlob(pngBlob => {
              if (!pngBlob) { reject(new Error('canvas.toBlob returned null')); return; }
              resolve(URL.createObjectURL(pngBlob));
            }, 'image/png');
          };
          img.onerror = (e) => { URL.revokeObjectURL(svgBlobUrl); reject(e); };
          img.src = svgBlobUrl;
        });
      }

      function triggerDownload(blobUrl, filename) {
        const a = document.createElement('a');
        a.href = blobUrl;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      }

      async function exportCurrentDiagramAsPng() {
        const filename = 'c4-' + currentExample + '-' + currentTab + '.png';
        const panel = document.getElementById(currentTab);
        if (!panel) return;
        const content = panel.querySelector('.example-content[data-example="' + currentExample + '"]');
        if (!content) return;
        if (currentRenderer === 'mermaid') {
          const svg = content.querySelector('.mermaid-view svg');
          if (!svg) return;
          const blobUrl = await svgToPngBlobUrl(svg);
          triggerDownload(blobUrl, filename);
          URL.revokeObjectURL(blobUrl);
        } else if (currentRenderer === '2d') {
          const svg = content.querySelector('.twoD-view svg');
          if (!svg) return;
          const blobUrl = await svgToPngBlobUrl(svg);
          triggerDownload(blobUrl, filename);
          URL.revokeObjectURL(blobUrl);
        } else if (currentRenderer === 'excalidraw') {
          const key = currentExample + '-' + currentTab;
          const exportFn = window._excalidrawApis?.[key];
          if (!exportFn) return;
          const blob = await exportFn();
          const url = URL.createObjectURL(blob);
          triggerDownload(url, filename);
          URL.revokeObjectURL(url);
        }
      }

      document.getElementById('export-png-btn')?.addEventListener('click', () => {
        exportCurrentDiagramAsPng();
      });

      function activateTab(target) {
        if (!validTabs.includes(target)) target = 'level1';
        currentTab = target;

        tabButtons.forEach(function (b) { b.classList.remove('active'); });
        tabPanels.forEach(function (p) { p.classList.remove('active'); });

        const activeBtn = document.querySelector('.tab-btn[data-tab="' + target + '"]');
        if (activeBtn) activeBtn.classList.add('active');

        const panel = document.getElementById(target);
        if (panel) {
          panel.classList.add('active');
          updateExampleVisibility(panel);

          // Render Mermaid diagrams when switching tabs in Mermaid mode
          if (currentRenderer === 'mermaid') {
            const activeContent = panel.querySelector('.example-content[data-example="' + currentExample + '"]');
            if (activeContent) renderMermaidInContent(activeContent);
          }
        }
        updateExportPngBtn();
      }

      tabButtons.forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          const target = btn.dataset.tab;
          history.pushState(null, '', '#' + target);
          activateTab(target);
        });
      });

      function activateFromHash() {
        const hash = window.location.hash.slice(1) || 'level1';
        activateTab(hash);
      }

      window.addEventListener('hashchange', activateFromHash);

      // ---- Example switching ----
      const exampleBtns = document.querySelectorAll('.example-btn');

      function activateExample(key) {
        if (!validExamples.includes(key)) key = 'banking';
        currentExample = key;

        exampleBtns.forEach(function (b) { b.classList.remove('active'); });
        const activeBtn = document.querySelector('.example-btn[data-example="' + key + '"]');
        if (activeBtn) activeBtn.classList.add('active');

        document.querySelectorAll('.tab-panel').forEach(function (panel) {
          updateExampleVisibility(panel);
        });

        // Render Mermaid diagrams for the newly selected example if in Mermaid mode
        if (currentRenderer === 'mermaid') {
          const activePanel = document.querySelector('.tab-panel.active');
          if (activePanel) {
            const activeContent = activePanel.querySelector('.example-content[data-example="' + key + '"]');
            if (activeContent) renderMermaidInContent(activeContent);
          }
        }
        updateExportPngBtn();
      }

      exampleBtns.forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          const key = btn.dataset.example;
          const url = new URL(window.location.href);
          url.searchParams.set('example', key);
          history.pushState(null, '', url.toString());
          activateExample(key);
        });
      });

      // ---- Initialize from URL params ----
      function init() {
        const params = new URLSearchParams(window.location.search);
        const example = params.get('example') || 'banking';
        const renderer = params.get('renderer') || 'excalidraw';
        activateExample(example);
        activateRenderer(renderer);
        activateFromHash();
      }

      window.addEventListener('popstate', init);
      init();
    </script>
    </div>
    <script>
      const btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.setAttribute('aria-label', document.documentElement.classList.contains('dark') ? 'Switch to light mode' : 'Switch to dark mode');
        btn.addEventListener('click', function () {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
        });
      }
    </script>
  </body>
</html>
