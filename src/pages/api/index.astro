---
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tooda API Explorer – browse and try the available JSON endpoints" />
    <title>API Explorer | Tooda</title>
    <link rel="stylesheet" href="/Tooda/swagger-ui.css" />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        @apply min-h-dvh bg-slate-900 font-sans text-slate-50;
        background-image:
          radial-gradient(ellipse 80% 50% at 50% -10%, rgba(99,102,241,0.2) 0%, transparent 70%),
          radial-gradient(ellipse 40% 40% at 90% 80%, rgba(139,92,246,0.12) 0%, transparent 60%),
          radial-gradient(ellipse 35% 35% at 10% 90%, rgba(56,189,248,0.10) 0%, transparent 60%);
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(99,102,241,0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(99,102,241,0.05) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 0;
      }

      header {
        @apply relative z-10 px-4 pb-4 pt-10 text-center;
      }

      header .badge {
        @apply mb-6 inline-flex items-center gap-2 rounded-full border border-indigo-500/40 bg-indigo-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-indigo-300;
      }

      header h1 {
        @apply mb-3 bg-gradient-to-br from-indigo-400 via-violet-400 to-sky-400 bg-clip-text text-[clamp(2rem,6vw,3.5rem)] font-extrabold leading-none tracking-tight text-transparent;
      }

      header p {
        @apply mx-auto max-w-[50ch] text-base leading-relaxed text-slate-400;
      }

      nav.back {
        @apply relative z-10 px-4 pb-6 pt-2 text-center;
      }

      nav.back a {
        @apply text-[0.9rem] text-violet-400 no-underline;
      }

      nav.back a:hover {
        @apply underline;
      }

      .swagger-wrapper {
        @apply relative z-10 mx-auto mb-12 max-w-5xl overflow-hidden rounded-2xl border border-slate-700/60 shadow-2xl shadow-indigo-500/5;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="badge">⚡ REST API</div>
      <h1>API Explorer</h1>
      <p>Browse, inspect, and test Tooda's JSON endpoints interactively — no install required.</p>
    </header>

    <nav class="back">
      <a href="/Tooda/">← Back to Home</a>
    </nav>

    <div class="swagger-wrapper">
      <div id="swagger-ui"></div>
    </div>

    <script src="/Tooda/swagger-ui-bundle.js" crossorigin></script>
    <script is:inline>
      window.onload = () => {
        SwaggerUIBundle({
          url: '/Tooda/api/openapi.json',
          dom_id: '#swagger-ui',
          presets: [SwaggerUIBundle.presets.apis],
          layout: 'BaseLayout',
          deepLinking: true,
        });
      };
    </script>
  </body>
</html>
