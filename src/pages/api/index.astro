---
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tooda API Explorer – browse and try the available JSON endpoints" />
    <title>API Explorer | Tooda</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        @apply min-h-dvh bg-slate-900 font-sans text-slate-50;
      }

      header {
        @apply px-4 pb-4 pt-8 text-center;
      }

      header h1 {
        @apply mb-2 bg-gradient-to-br from-indigo-500 via-violet-400 to-sky-400 bg-clip-text text-[clamp(2rem,6vw,3.5rem)] font-extrabold text-transparent;
      }

      header p {
        @apply text-base text-slate-400;
      }

      nav.back {
        @apply px-4 pb-6 pt-2 text-center;
      }

      nav.back a {
        @apply text-[0.9rem] text-violet-400 no-underline;
      }

      nav.back a:hover {
        @apply underline;
      }

      main {
        @apply mx-auto max-w-3xl px-4 pb-16;
      }

      .section-title {
        @apply mb-4 text-xl font-bold text-slate-200;
      }

      .endpoint-group {
        @apply mb-10;
      }

      .endpoint-card {
        @apply mb-4 overflow-hidden rounded-xl border border-slate-700 bg-slate-800;
      }

      .endpoint-header {
        @apply flex items-center gap-3 px-5 py-4;
      }

      .method-badge {
        @apply shrink-0 rounded-md bg-indigo-600 px-2 py-0.5 font-mono text-xs font-bold text-white;
      }

      .endpoint-path {
        @apply flex-1 break-all font-mono text-sm text-slate-200;
      }

      .endpoint-description {
        @apply text-[0.85rem] text-slate-400;
      }

      .try-btn {
        @apply ml-auto shrink-0 cursor-pointer rounded-lg border border-slate-600 bg-slate-700 px-4 py-1.5 text-[0.85rem] text-slate-300 transition-all duration-200 no-underline;
      }

      .try-btn:hover {
        @apply bg-slate-600 text-slate-50;
      }

      .try-btn.loading {
        @apply cursor-wait opacity-70;
      }

      .response-panel {
        @apply hidden border-t border-slate-700 bg-slate-900 p-5;
      }

      .response-panel.visible {
        @apply block;
      }

      .response-meta {
        @apply mb-2 flex items-center gap-3 text-[0.8rem];
      }

      .status-ok {
        @apply font-semibold text-emerald-400;
      }

      .status-err {
        @apply font-semibold text-rose-400;
      }

      .response-time {
        @apply text-slate-500;
      }

      .response-body {
        @apply max-h-72 overflow-auto rounded-lg border border-slate-700 bg-slate-800 p-4 font-mono text-xs leading-relaxed text-slate-300;
      }

      .open-btn {
        @apply mt-3 inline-block rounded-lg border border-slate-600 bg-slate-800 px-4 py-1.5 text-[0.85rem] text-violet-400 no-underline transition-all duration-200;
      }

      .open-btn:hover {
        @apply bg-slate-700 text-violet-300 underline;
      }

      .spec-banner {
        @apply mx-auto mb-8 max-w-3xl rounded-xl border border-indigo-700 bg-slate-800 px-5 py-4 text-sm text-slate-300;
      }

      .spec-banner a {
        @apply font-semibold text-violet-400 no-underline;
      }

      .spec-banner a:hover {
        @apply underline;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>API Explorer</h1>
      <p>Browse and try the available JSON endpoints</p>
    </header>

    <nav class="back">
      <a href="/Tooda/">← Back to Home</a>
    </nav>

    <div class="spec-banner" role="note" aria-label="OpenAPI specification">
      📄 Machine-readable spec: <a href="/Tooda/api/openapi.json">OpenAPI 3.0 — /api/openapi.json</a>
    </div>

    <main>
      <!-- C4 Diagram Endpoints -->
      <section class="endpoint-group" aria-label="C4 diagram endpoints">
        <h2 class="section-title">C4 Diagram Endpoints</h2>

        <div class="endpoint-card" data-endpoint="/Tooda/api/c4/banking.json">
          <div class="endpoint-header">
            <span class="method-badge">GET</span>
            <div>
              <div class="endpoint-path">/api/c4/banking.json</div>
              <div class="endpoint-description">Online Banking System — all four C4 levels</div>
            </div>
            <button class="try-btn" aria-label="Try /api/c4/banking.json">Try it</button>
          </div>
          <div class="response-panel" aria-live="polite"></div>
        </div>

        <div class="endpoint-card" data-endpoint="/Tooda/api/c4/ecommerce.json">
          <div class="endpoint-header">
            <span class="method-badge">GET</span>
            <div>
              <div class="endpoint-path">/api/c4/ecommerce.json</div>
              <div class="endpoint-description">E-Commerce Platform — all four C4 levels</div>
            </div>
            <button class="try-btn" aria-label="Try /api/c4/ecommerce.json">Try it</button>
          </div>
          <div class="response-panel" aria-live="polite"></div>
        </div>

        <div class="endpoint-card" data-endpoint="/Tooda/api/c4/ridesharing.json">
          <div class="endpoint-header">
            <span class="method-badge">GET</span>
            <div>
              <div class="endpoint-path">/api/c4/ridesharing.json</div>
              <div class="endpoint-description">Ride-Sharing App — all four C4 levels</div>
            </div>
            <button class="try-btn" aria-label="Try /api/c4/ridesharing.json">Try it</button>
          </div>
          <div class="response-panel" aria-live="polite"></div>
        </div>
      </section>

      <!-- Excalidraw Endpoints -->
      <section class="endpoint-group" aria-label="Excalidraw endpoints">
        <h2 class="section-title">Excalidraw Endpoints</h2>

        <div class="endpoint-card" data-endpoint="/Tooda/api/excalidraw/level1.json">
          <div class="endpoint-header">
            <span class="method-badge">GET</span>
            <div>
              <div class="endpoint-path">/api/excalidraw/level1.json</div>
              <div class="endpoint-description">Healthcare Platform — Level 1 (Context)</div>
            </div>
            <button class="try-btn" aria-label="Try /api/excalidraw/level1.json">Try it</button>
          </div>
          <div class="response-panel" aria-live="polite"></div>
        </div>

        <div class="endpoint-card" data-endpoint="/Tooda/api/excalidraw/level2.json">
          <div class="endpoint-header">
            <span class="method-badge">GET</span>
            <div>
              <div class="endpoint-path">/api/excalidraw/level2.json</div>
              <div class="endpoint-description">Healthcare Platform — Level 2 (Container)</div>
            </div>
            <button class="try-btn" aria-label="Try /api/excalidraw/level2.json">Try it</button>
          </div>
          <div class="response-panel" aria-live="polite"></div>
        </div>

        <div class="endpoint-card" data-endpoint="/Tooda/api/excalidraw/level3.json">
          <div class="endpoint-header">
            <span class="method-badge">GET</span>
            <div>
              <div class="endpoint-path">/api/excalidraw/level3.json</div>
              <div class="endpoint-description">Healthcare Platform — Level 3 (Component)</div>
            </div>
            <button class="try-btn" aria-label="Try /api/excalidraw/level3.json">Try it</button>
          </div>
          <div class="response-panel" aria-live="polite"></div>
        </div>

        <div class="endpoint-card" data-endpoint="/Tooda/api/excalidraw/level4.json">
          <div class="endpoint-header">
            <span class="method-badge">GET</span>
            <div>
              <div class="endpoint-path">/api/excalidraw/level4.json</div>
              <div class="endpoint-description">Healthcare Platform — Level 4 (Code)</div>
            </div>
            <button class="try-btn" aria-label="Try /api/excalidraw/level4.json">Try it</button>
          </div>
          <div class="response-panel" aria-live="polite"></div>
        </div>
      </section>
    </main>

    <script is:inline>
      document.querySelectorAll('.endpoint-card').forEach(card => {
        const endpoint = card.dataset.endpoint;
        const btn = card.querySelector('.try-btn');
        const panel = card.querySelector('.response-panel');

        btn.addEventListener('click', async () => {
          if (btn.classList.contains('loading')) return;

          // Toggle: if already showing a response, close it
          if (panel.classList.contains('visible')) {
            panel.classList.remove('visible');
            btn.textContent = 'Try it';
            return;
          }

          btn.classList.add('loading');
          btn.textContent = 'Loading…';

          const start = Date.now();
          try {
            const res = await fetch(endpoint);
            const elapsed = Date.now() - start;
            const data = await res.json();
            const pretty = JSON.stringify(data, null, 2);

            panel.innerHTML = `
              <div class="response-meta">
                <span class="${res.ok ? 'status-ok' : 'status-err'}">${res.status} ${res.statusText}</span>
                <span class="response-time">${elapsed} ms</span>
              </div>
              <pre class="response-body"><code>${escapeHtml(pretty)}</code></pre>
              <a href="${endpoint}" target="_blank" rel="noopener noreferrer" class="open-btn">Open raw JSON ↗</a>
            `;
            panel.classList.add('visible');
            btn.textContent = 'Close';
          } catch (err) {
            const elapsed = Date.now() - start;
            panel.innerHTML = `
              <div class="response-meta">
                <span class="status-err">Network error</span>
                <span class="response-time">${elapsed} ms</span>
              </div>
              <pre class="response-body"><code>${escapeHtml(String(err))}</code></pre>
            `;
            panel.classList.add('visible');
            btn.textContent = 'Close';
          } finally {
            btn.classList.remove('loading');
          }
        });
      });

      function escapeHtml(str) {
        return str
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }
    </script>
  </body>
</html>
