  ...makeBox('l2-queue',   890, 340, 140, 60, 'Message Queue\n(RabbitMQ)', '#fde68a'),
  // Arrows: users → frontend (short, near-horizontal)
  ...makeArrow('l2-a1', 140, 160, 60, -30, 'HTTPS'),
  ...makeArrow('l2-a2', 140, 300, 60, -30, 'HTTPS'),
  // Arrows: frontend → API Gateway (converging)
  ...makeArrow('l2-a3', 360, 130, 70,  70, 'JSON/HTTPS'),
