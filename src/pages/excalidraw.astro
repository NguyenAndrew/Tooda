<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Healthcare Platform – illustrated using Excalidraw across all 4 levels of the C4 model" />
    <title>Excalidraw Example | Tooda</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
          Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        background-color: #0f172a;
        color: #f8fafc;
        min-height: 100dvh;
      }

      header {
        text-align: center;
        padding: 2rem 1rem 1rem;
      }

      header h1 {
        font-size: clamp(2rem, 6vw, 3.5rem);
        font-weight: 800;
        background: linear-gradient(135deg, #6366f1, #a78bfa, #38bdf8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.5rem;
      }

      header p {
        color: #94a3b8;
        font-size: 1rem;
      }

      nav.back {
        text-align: center;
        padding: 0.5rem 1rem 1.5rem;
      }

      nav.back a {
        color: #a78bfa;
        text-decoration: none;
        font-size: 0.9rem;
      }

      nav.back a:hover {
        text-decoration: underline;
      }

      .tabs {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        flex-wrap: wrap;
        padding: 0 1rem;
        margin-bottom: 2rem;
      }

      .tab-btn {
        display: inline-block;
        text-decoration: none;
        background: #1e293b;
        color: #94a3b8;
        border: 1px solid #334155;
        border-radius: 0.5rem;
        padding: 0.5rem 1.25rem;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background 0.2s, color 0.2s, border-color 0.2s;
      }

      .tab-btn:hover {
        background: #334155;
        color: #f8fafc;
      }

      .tab-btn.active {
        background: linear-gradient(135deg, #6366f1, #a78bfa);
        color: #fff;
        border-color: transparent;
      }

      .tab-panel {
        display: none;
        max-width: 960px;
        margin: 0 auto;
        padding: 0 1rem 3rem;
      }

      .tab-panel.active {
        display: block;
      }

      .tab-panel h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #e2e8f0;
        margin-bottom: 0.5rem;
      }

      .tab-panel .description {
        color: #94a3b8;
        margin-bottom: 1.5rem;
        line-height: 1.6;
        font-size: 0.95rem;
      }

      .diagram-wrapper {
        background: #fff;
        border-radius: 0.75rem;
        overflow: hidden;
      }
    </style>
