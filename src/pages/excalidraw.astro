  // Actors
  ...makeBox('l1-patient',   50,  120, 140, 60, 'Patient',          '#bfdbfe'),
  ...makeBox('l1-doctor',    50,  240, 140, 60, 'Doctor',           '#bfdbfe'),
  ...makeBox('l1-admin',     50,  360, 140, 60, 'Admin',            '#bfdbfe'),
  // Main system
  ...makeBox('l1-platform',  280, 200, 200, 100, 'Healthcare\nPlatform', '#bbf7d0'),
  // External systems
  ...makeBox('l1-pharmacy',  570, 120, 160, 60, 'Pharmacy\nSystem',  '#fef9c3'),
  ...makeBox('l1-insurance', 570, 240, 160, 60, 'Insurance\nSystem', '#fef9c3'),
  ...makeBox('l1-lab',       570, 360, 160, 60, 'Laboratory\nSystem','#fef9c3'),
  // Arrows: actors → platform
