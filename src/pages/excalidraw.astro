    strokeWidth: 1, strokeStyle: 'solid', roughness: 1, opacity: 100,
    groupIds: [], frameId: null, roundness: null, seed: 10, version: 1, versionNonce: 1,
    isDeleted: false, boundElements: null, updated: 1, link: null, locked: false,
    text: 'Component – EMR Service', fontSize: 20, fontFamily: 1,
    textAlign: 'center', verticalAlign: 'middle', containerId: null,
    originalText: 'Component – EMR Service', autoResize: true, lineHeight: 1.25,
  },
  // External
  ...makeBox('l3-gateway', 20,  200, 140, 60, 'API Gateway',       '#bfdbfe'),
  ...makeBox('l3-db',     660,  200, 140, 60, 'Database\n(PostgreSQL)', '#fde68a'),
  // Components inside EMR Service
  ...makeBox('l3-ctrl',   200,  100, 160, 60, 'Record\nController',    '#bbf7d0'),
  ...makeBox('l3-svc',    200,  220, 160, 60, 'Record\nService',       '#bbf7d0'),
