    groupIds: [], frameId: null, roundness: null, seed: 10, version: 1, versionNonce: 1,
    isDeleted: false, boundElements: null, updated: 1, link: null, locked: false,
    text: 'System Context – Healthcare Platform',
    fontSize: 20, fontFamily: 1, textAlign: 'center', verticalAlign: 'middle',
    containerId: null, originalText: 'System Context – Healthcare Platform',
    autoResize: true, lineHeight: 1.25,
