---
import ExcalidrawViewer from '../components/ExcalidrawViewer';
import HealthcarePlatform2D from '../components/HealthcarePlatform2D';
import HealthcarePlatform3D from '../components/HealthcarePlatform3D';
import {
  level1Elements,
  level2Elements,
  level3Elements,
  level4Elements,
  mermaidDiagrams,
  levelConnections,
} from '../data/healthcare/diagrams';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Healthcare Platform – illustrated using Excalidraw and Mermaid across all 4 levels of the C4 model" />
    <title>Excalidraw Example | Tooda</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background-color: #0f172a;
        background-image:
          radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99,102,241,0.25) 0%, transparent 70%),
          radial-gradient(ellipse 50% 40% at 90% 80%, rgba(139,92,246,0.15) 0%, transparent 60%),
          radial-gradient(ellipse 40% 40% at 10% 90%, rgba(56,189,248,0.12) 0%, transparent 60%);
        @apply min-h-dvh font-sans text-slate-50;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(99,102,241,0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(99,102,241,0.06) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 0;
      }

      .page-content {
        position: relative;
        z-index: 1;
      }

      @keyframes glow-pulse {
        0%, 100% { filter: drop-shadow(0 0 16px rgba(139,92,246,0.5)); }
        50%       { filter: drop-shadow(0 0 36px rgba(99,102,241,0.8)); }
      }

      header {
        @apply px-4 pb-4 pt-8 text-center;
      }

      header h1 {
        animation: glow-pulse 3s ease-in-out infinite;
        @apply mb-2 bg-gradient-to-br from-indigo-500 via-violet-400 to-sky-400 bg-clip-text text-[clamp(2rem,6vw,3.5rem)] font-extrabold text-transparent;
      }

      header p {
        @apply text-base text-slate-400;
      }

      nav.back {
        @apply px-4 pb-6 pt-2 text-center;
      }

      nav.back a {
        @apply text-[0.9rem] text-violet-400 no-underline;
      }

      nav.back a:hover {
        @apply underline;
      }

      .renderer-toggle {
        @apply mb-4 flex flex-wrap justify-center gap-2 px-4;
      }

      .renderer-btn {
        @apply inline-block cursor-pointer rounded-lg border border-slate-700 bg-slate-800 px-5 py-2 text-[0.95rem] text-slate-400 no-underline transition-all duration-200;
      }

      .renderer-btn:hover {
        @apply bg-slate-700 text-slate-50;
      }

      .renderer-btn.active {
        @apply border-transparent bg-gradient-to-br from-violet-500 to-sky-400 text-white;
      }

      .tabs {
        @apply mb-8 flex flex-wrap justify-center gap-2 px-4;
      }

      .tab-btn {
        @apply inline-block cursor-pointer rounded-lg border border-slate-700 bg-slate-800 px-5 py-2 text-[0.95rem] text-slate-400 no-underline transition-all duration-200;
      }

      .tab-btn:hover {
        @apply bg-slate-700 text-slate-50;
      }

      .tab-btn.active {
        @apply border-transparent bg-gradient-to-br from-indigo-500 to-violet-400 text-white;
      }

      .tab-panel {
        @apply mx-auto hidden max-w-[960px] px-4 pb-12;
      }

      .tab-panel.active {
        @apply block;
      }

      .tab-panel h2 {
        @apply mb-2 text-2xl font-bold text-slate-200;
      }

      .tab-panel .description {
        @apply mb-6 text-[0.95rem] leading-relaxed text-slate-400;
      }

      .diagram-wrapper {
        @apply overflow-hidden rounded-xl bg-white;
      }

      .mermaid-wrapper {
        @apply hidden overflow-hidden rounded-xl bg-white p-6;
      }

      .mermaid-wrapper .mermaid {
        @apply flex justify-center;
      }

      .threeD-wrapper {
        @apply hidden overflow-hidden rounded-xl;
      }

      .twoD-wrapper {
        @apply hidden overflow-hidden rounded-xl bg-slate-900;
      }

      .export-png-btn {
        @apply inline-block cursor-pointer rounded-lg border border-slate-700 bg-slate-800 px-5 py-2 text-[0.95rem] text-slate-400 no-underline transition-all duration-200;
      }

      .export-png-btn:hover {
        @apply bg-slate-700 text-slate-50;
      }
    </style>
  </head>
  <body>
    <div class="page-content">
    <header>
      <h1>Healthcare Platform</h1>
      <p>An architecture example illustrated using Excalidraw and Mermaid across all 4 levels of the C4 model</p>
    </header>

    <nav class="back">
      <a href="/Tooda/">← Back to Home</a>
    </nav>

    <div class="renderer-toggle">
      <a href="?renderer=excalidraw" class="renderer-btn active" data-renderer="excalidraw">&#9999;&#65039; Excalidraw</a>
      <a href="?renderer=mermaid" class="renderer-btn" data-renderer="mermaid">&#128202; Mermaid</a>
      <a href="?renderer=2d" class="renderer-btn" data-renderer="2d">&#128506;&#65039; 2D</a>
      <a href="?renderer=3d" class="renderer-btn" data-renderer="3d">&#127922; 3D</a>
    </div>

    <div class="tabs">
      <a href="#level1" class="tab-btn active" data-tab="level1">Level 1 – Context</a>
      <a href="#level2" class="tab-btn" data-tab="level2">Level 2 – Container</a>
      <a href="#level3" class="tab-btn" data-tab="level3">Level 3 – Component</a>
      <a href="#level4" class="tab-btn" data-tab="level4">Level 4 – Code</a>
    </div>

    <div id="export-png-container" class="mb-6 flex justify-center px-4">
      <a
        id="export-png-btn"
        href="/Tooda/api/healthcare/excalidraw/level1.png"
        download="healthcare-excalidraw-level1.png"
        class="export-png-btn"
        data-testid="export-png-btn"
      >&#128247; Export PNG</a>
    </div>

    <!-- Level 1: System Context -->
    <section id="level1" class="tab-panel active">
      <h2>Level 1 – System Context</h2>
      <p class="description">
        Shows the Healthcare Platform in context: who uses it and which external systems it
        interacts with.
      </p>
      <div class="diagram-wrapper excalidraw-view">
        <ExcalidrawViewer client:only="react" elements={level1Elements} />
      </div>
      <div class="mermaid-wrapper mermaid-view">
        <div class="mermaid" set:text={mermaidDiagrams.level1}></div>
      </div>
      <div class="twoD-wrapper twoD-view">
        <HealthcarePlatform2D client:only="react" level={1} connections={levelConnections.level1} />
      </div>
      <div class="threeD-wrapper threeD-view">
        <HealthcarePlatform3D client:only="react" level={1} connections={levelConnections.level1} />
      </div>
    </section>

    <!-- Level 2: Container -->
    <section id="level2" class="tab-panel">
      <h2>Level 2 – Container</h2>
      <p class="description">
        Zooms in on the Healthcare Platform to show the containers (applications and data
        stores) that make it up.
      </p>
      <div class="diagram-wrapper excalidraw-view">
        <ExcalidrawViewer client:only="react" elements={level2Elements} />
      </div>
      <div class="mermaid-wrapper mermaid-view">
        <div class="mermaid" set:text={mermaidDiagrams.level2}></div>
      </div>
      <div class="twoD-wrapper twoD-view">
        <HealthcarePlatform2D client:only="react" level={2} connections={levelConnections.level2} />
      </div>
      <div class="threeD-wrapper threeD-view">
        <HealthcarePlatform3D client:only="react" level={2} connections={levelConnections.level2} />
      </div>
    </section>

    <!-- Level 3: Component -->
    <section id="level3" class="tab-panel">
      <h2>Level 3 – Component</h2>
      <p class="description">
        Zooms in on the EMR Service to show the components (controllers, services, and
        repositories) inside it.
      </p>
      <div class="diagram-wrapper excalidraw-view">
        <ExcalidrawViewer client:only="react" elements={level3Elements} />
      </div>
      <div class="mermaid-wrapper mermaid-view">
        <div class="mermaid" set:text={mermaidDiagrams.level3}></div>
      </div>
      <div class="twoD-wrapper twoD-view">
        <HealthcarePlatform2D client:only="react" level={3} connections={levelConnections.level3} />
      </div>
      <div class="threeD-wrapper threeD-view">
        <HealthcarePlatform3D client:only="react" level={3} connections={levelConnections.level3} />
      </div>
    </section>

    <!-- Level 4: Code -->
    <section id="level4" class="tab-panel">
      <h2>Level 4 – Code</h2>
      <p class="description">
        Zooms in on the Record Service to show the classes and interfaces that implement it.
      </p>
      <div class="diagram-wrapper excalidraw-view">
        <ExcalidrawViewer client:only="react" elements={level4Elements} />
      </div>
      <div class="mermaid-wrapper mermaid-view">
        <div class="mermaid" set:text={mermaidDiagrams.level4}></div>
      </div>
      <div class="twoD-wrapper twoD-view">
        <HealthcarePlatform2D client:only="react" level={4} connections={levelConnections.level4} />
      </div>
      <div class="threeD-wrapper threeD-view">
        <HealthcarePlatform3D client:only="react" level={4} connections={levelConnections.level4} />
      </div>
    </section>

    <script src="/Tooda/mermaid.min.js" is:inline></script>
    <script type="module">
      const { default: elkLayouts } = await import('/Tooda/mermaid-layout-elk.esm.min.mjs');
      mermaid.registerLayoutLoaders(elkLayouts);
      window._resolveElk();
    </script>
    <script is:inline>
      // ELK layout engine is loaded asynchronously; all mermaid.run() calls wait for it.
      window._elkReady = new Promise(resolve => { window._resolveElk = resolve; });

      mermaid.initialize({ startOnLoad: false, theme: 'default' });

      const tabs = document.querySelectorAll('.tab-btn');
      const panels = document.querySelectorAll('.tab-panel');
      const rendererBtns = document.querySelectorAll('.renderer-btn');
      const validTabs = ['level1', 'level2', 'level3', 'level4'];

      let currentRenderer = 'excalidraw';
      let currentLevel = 'level1';

      // ── Export PNG button ─────────────────────────────────────────────────────

      function updateExportPngBtn() {
        const container = document.getElementById('export-png-container');
        if (!container) return;
        if (currentRenderer === '3d') {
          container.style.display = 'none';
          return;
        }
        container.style.display = '';
        const btn = document.getElementById('export-png-btn');
        if (!btn) return;
        const href = '/Tooda/api/healthcare/' + currentRenderer + '/' + currentLevel + '.png';
        btn.setAttribute('href', href);
        btn.setAttribute('download', 'healthcare-' + currentRenderer + '-' + currentLevel + '.png');
      }

      // ── Renderer toggle ──────────────────────────────────────────────────────

      function activateRenderer(renderer) {
        if (renderer !== 'excalidraw' && renderer !== 'mermaid' && renderer !== '3d' && renderer !== '2d') renderer = 'excalidraw';
        currentRenderer = renderer;

        rendererBtns.forEach(b => b.classList.remove('active'));
        const activeBtn = document.querySelector('.renderer-btn[data-renderer="' + renderer + '"]');
        if (activeBtn) activeBtn.classList.add('active');

        const excalidrawViews = document.querySelectorAll('.excalidraw-view');
        const mermaidViews = document.querySelectorAll('.mermaid-view');
        const twoDViews = document.querySelectorAll('.twoD-view');
        const threeDViews = document.querySelectorAll('.threeD-view');

        excalidrawViews.forEach(el => { el.style.display = 'none'; });
        mermaidViews.forEach(el => { el.style.display = 'none'; });
        twoDViews.forEach(el => { el.style.display = 'none'; });
        threeDViews.forEach(el => { el.style.display = 'none'; });

        if (renderer === 'excalidraw') {
          excalidrawViews.forEach(el => { el.style.display = 'block'; });
        } else if (renderer === 'mermaid') {
          mermaidViews.forEach(el => { el.style.display = 'block'; });

          // Render any un-rendered Mermaid diagrams in the active panel
          const activePanel = document.querySelector('.tab-panel.active');
          if (activePanel) {
            const unrendered = Array.from(activePanel.querySelectorAll('.mermaid')).filter(
              el => !el.querySelector('svg')
            );
            if (unrendered.length > 0) {
              unrendered.forEach(el => el.removeAttribute('data-processed'));
              window._elkReady.then(() => mermaid.run({ nodes: unrendered }));
            }
          }
        } else if (renderer === '2d') {
          twoDViews.forEach(el => { el.style.display = 'block'; });
        } else {
          threeDViews.forEach(el => { el.style.display = 'block'; });
        }

        updateExportPngBtn();
      }

      rendererBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const renderer = btn.dataset.renderer;
          const url = new URL(window.location.href);
          url.searchParams.set('renderer', renderer);
          history.pushState(null, '', url.toString());
          activateRenderer(renderer);
        });
      });

      // ── Tab switching ─────────────────────────────────────────────────────────

      function activateTab(target) {
        if (!validTabs.includes(target)) target = 'level1';
        currentLevel = target;
        tabs.forEach(b => b.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        const activeBtn = document.querySelector('.tab-btn[data-tab="' + target + '"]');
        if (activeBtn) activeBtn.classList.add('active');
        const panel = document.getElementById(target);
        if (panel) {
          panel.classList.add('active');

          // Render any un-rendered Mermaid diagrams when switching tabs in Mermaid mode
          if (currentRenderer === 'mermaid') {
            const unrendered = Array.from(panel.querySelectorAll('.mermaid')).filter(
              el => !el.querySelector('svg')
            );
            if (unrendered.length > 0) {
              unrendered.forEach(el => el.removeAttribute('data-processed'));
              window._elkReady.then(() => mermaid.run({ nodes: unrendered }));
            }
          }
        }

        updateExportPngBtn();
      }

      tabs.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const target = btn.dataset.tab;
          history.pushState(null, '', '#' + target);
          activateTab(target);
        });
      });

      function activateFromHash() {
        const hash = window.location.hash.slice(1) || 'level1';
        activateTab(hash);
      }

      // ── Init from URL ─────────────────────────────────────────────────────────

      function activateFromQuery() {
        const params = new URLSearchParams(window.location.search);
        const renderer = params.get('renderer') || 'excalidraw';
        activateRenderer(renderer);
      }

      window.addEventListener('popstate', () => {
        activateFromQuery();
        activateFromHash();
      });

      window.addEventListener('hashchange', activateFromHash);

      activateFromQuery();
      activateFromHash();
    </script>
    </div>
  </body>
</html>
