---
import ExcalidrawViewer from '../components/ExcalidrawViewer';
import HealthcarePlatform2D from '../components/HealthcarePlatform2D';
import HealthcarePlatform3D from '../components/HealthcarePlatform3D';
import {
  level1Elements,
  level2Elements,
  level3Elements,
  level4Elements,
  mermaidDiagrams,
  levelConnections,
} from '../data/healthcare/diagrams';
import { LEVEL_NODES } from '../data/healthcare/nodes';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <meta name="description" content="Healthcare Platform – illustrated using Excalidraw and Mermaid across all 4 levels of the C4 model" />
    <title>Excalidraw Example | Tooda</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme = stored === 'light' ? 'light' : 'dark';
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg-color: #f8fafc;
        --grad1: rgba(20,184,166,0.15);
        --grad2: rgba(6,182,212,0.10);
        --grad3: rgba(16,185,129,0.07);
        --grid-line: rgba(20,184,166,0.04);
      }

      :root.dark {
        --bg-color: #0f172a;
        --grad1: rgba(20,184,166,0.28);
        --grad2: rgba(6,182,212,0.18);
        --grad3: rgba(16,185,129,0.14);
        --grid-line: rgba(20,184,166,0.08);
      }

      body {
        background-color: var(--bg-color);
        background-image:
          radial-gradient(ellipse 80% 60% at 50% -10%, var(--grad1) 0%, transparent 70%),
          radial-gradient(ellipse 50% 40% at 90% 80%, var(--grad2) 0%, transparent 60%),
          radial-gradient(ellipse 40% 40% at 10% 90%, var(--grad3) 0%, transparent 60%);
        @apply min-h-dvh font-sans text-slate-900 dark:text-slate-50;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--grid-line) 1px, transparent 1px),
          linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 0;
      }

      .page-content {
        position: relative;
        z-index: 1;
      }

      @keyframes glow-pulse {
        0%, 100% { filter: drop-shadow(0 0 16px rgba(20,184,166,0.5)); }
        50%       { filter: drop-shadow(0 0 36px rgba(6,182,212,0.8)); }
      }

      header {
        @apply px-4 pb-4 pt-8 text-center;
      }

      header h1 {
        animation: glow-pulse 3s ease-in-out infinite;
        @apply mb-2 bg-gradient-to-br from-teal-500 via-cyan-400 to-emerald-400 bg-clip-text text-[clamp(2rem,6vw,3.5rem)] font-extrabold text-transparent;
      }

      header p {
        @apply mb-3 text-base text-slate-500 dark:text-slate-400;
      }

      header .back-link {
        @apply inline-block text-[0.9rem] text-teal-600 no-underline dark:text-teal-400;
      }

      header .back-link:hover {
        @apply underline;
      }

      /* ── Controls panel: visually groups Renderer / Level rows ── */
      .controls-panel {
        @apply mx-auto mb-8 max-w-[960px] overflow-hidden rounded-2xl border border-slate-200/70 bg-white/40 backdrop-blur-sm dark:border-slate-700/50 dark:bg-slate-800/30;
        box-shadow: 0 4px 24px rgba(20,184,166,0.06), 0 1px 4px rgba(0,0,0,0.04);
      }

      .controls-section {
        @apply px-4 py-4;
      }

      .controls-section + .controls-section {
        @apply border-t border-slate-200/60 dark:border-slate-700/40;
      }

      .controls-label {
        @apply mb-2 block text-center text-[0.65rem] font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500;
      }

      .export-area {
        @apply mt-3 flex justify-center;
      }

      .renderer-toggle {
        @apply flex flex-wrap justify-center gap-2;
      }

      /* ── Shared pill button base (renderer / tab) ── */
      .renderer-btn,
      .tab-btn,
      .export-png-btn {
        position: relative;
        overflow: hidden;
        @apply inline-block cursor-pointer rounded-full border border-slate-300/80 bg-white/60 px-5 py-2 text-[0.9rem] font-medium text-slate-600 no-underline backdrop-blur-sm transition-all duration-200 dark:border-slate-700/80 dark:bg-slate-800/60 dark:text-slate-400;
      }

      .renderer-btn:hover,
      .tab-btn:hover,
      .export-png-btn:hover {
        @apply border-teal-400/60 text-slate-900 dark:border-teal-500/60 dark:text-slate-50;
        transform: translateY(-1px);
        box-shadow: 0 3px 10px rgba(20,184,166,0.12), 0 1px 3px rgba(0,0,0,0.05);
      }

      /* ── Active state: gradient pill with subtle glow ── */
      @keyframes active-glow-pulse {
        0%, 100% {
          box-shadow:
            0 0 6px  rgba(20,184,166,0.4),
            0 0 14px rgba(20,184,166,0.2),
            inset 0 1px 0 rgba(255,255,255,0.2);
        }
        50% {
          box-shadow:
            0 0 10px rgba(20,184,166,0.55),
            0 0 22px rgba(6,182,212,0.25),
            inset 0 1px 0 rgba(255,255,255,0.2);
        }
      }

      .renderer-btn.active,
      .tab-btn.active {
        border-color: transparent;
        background: linear-gradient(135deg, #14b8a6, #06b6d4, #10b981);
        color: #fff;
        font-weight: 600;
        box-shadow:
          0 0 6px  rgba(20,184,166,0.4),
          0 0 14px rgba(20,184,166,0.2),
          inset 0 1px 0 rgba(255,255,255,0.2);
      }

      @media (prefers-reduced-motion: no-preference) {
        .renderer-btn.active,
        .tab-btn.active {
          animation: active-glow-pulse 3s ease-in-out infinite;
        }
      }

      .tabs {
        @apply flex flex-wrap justify-center gap-2;
      }

      .tab-panel {
        @apply mx-auto hidden max-w-[960px] px-4 pb-12;
      }

      .tab-panel.active {
        @apply block;
        animation: panel-enter 0.25s ease forwards;
      }

      @keyframes panel-enter {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @media (prefers-reduced-motion: reduce) {
        .tab-panel.active {
          animation: none;
        }
      }

      .tab-panel h2 {
        @apply mb-2 text-2xl font-bold text-slate-700 dark:text-slate-200;
      }

      .tab-panel .description {
        @apply mb-6 text-[0.95rem] leading-relaxed text-slate-500 dark:text-slate-400;
      }

      .diagram-wrapper {
        @apply overflow-hidden rounded-xl bg-white;
      }

      .mermaid-wrapper {
        @apply hidden overflow-hidden rounded-xl bg-white p-6;
      }

      .mermaid-wrapper .mermaid {
        @apply flex justify-center;
      }

      .threeD-wrapper {
        @apply hidden overflow-hidden rounded-xl;
      }

      .twoD-wrapper {
        @apply hidden overflow-hidden rounded-xl bg-slate-900;
      }

      /* Theme toggle button */
      .theme-toggle-btn {
        @apply fixed right-4 top-4 z-50 flex h-10 w-10 items-center justify-center rounded-full border border-slate-300 bg-white/80 text-slate-600 shadow-md backdrop-blur-sm transition-all duration-200 dark:border-slate-700 dark:bg-slate-800/80 dark:text-slate-300;
      }

      @media (hover: hover) {
        .theme-toggle-btn:hover {
          border-color: rgba(20,184,166,0.6);
          box-shadow: 0 0 12px rgba(20,184,166,0.3), 0 2px 8px rgba(0,0,0,0.1);
          transform: rotate(10deg) scale(1.05);
        }
      }
    </style>
  </head>
  <body>
    <!-- Theme toggle button -->
    <button id="theme-toggle" type="button" aria-label="Switch to light mode" class="theme-toggle-btn">
      <svg class="hidden size-5 dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="block size-5 dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <div class="page-content">
    <header>
      <h1>Healthcare Platform</h1>
      <p>An architecture example illustrated using Excalidraw and Mermaid across all 4 levels of the C4 model</p>
      <a href="/Tooda/" class="back-link">← Back to Home</a>
    </header>

    <div class="controls-panel">
      <div class="controls-section">
        <span class="controls-label">Renderer</span>
        <div class="renderer-toggle">
          <a href="?renderer=excalidraw" class="renderer-btn active" data-renderer="excalidraw">&#9999;&#65039; Excalidraw</a>
          <a href="?renderer=mermaid" class="renderer-btn" data-renderer="mermaid">&#128202; Mermaid</a>
          <a href="?renderer=2d" class="renderer-btn" data-renderer="2d">&#128506;&#65039; 2D</a>
          <a href="?renderer=3d" class="renderer-btn" data-renderer="3d">&#127922; 3D</a>
        </div>
      </div>

      <div class="controls-section">
        <span class="controls-label">Level</span>
        <div class="tabs">
          <a href="#level1" class="tab-btn active" data-tab="level1">Level 1 – Context</a>
          <a href="#level2" class="tab-btn" data-tab="level2">Level 2 – Container</a>
          <a href="#level3" class="tab-btn" data-tab="level3">Level 3 – Component</a>
          <a href="#level4" class="tab-btn" data-tab="level4">Level 4 – Code</a>
        </div>
        <div class="export-area">
          <a
            id="export-png-btn"
            href="/Tooda/api/healthcare/excalidraw/level1.png"
            download="healthcare-excalidraw-level1.png"
            class="export-png-btn"
            data-testid="export-png-btn"
          >&#128247; Export PNG</a>
        </div>
      </div>
    </div>

    <!-- Level 1: System Context -->
    <section id="level1" class="tab-panel active">
      <h2>Level 1 – System Context</h2>
      <p class="description">
        Shows the Healthcare Platform in context: who uses it and which external systems it
        interacts with.
      </p>
      <div class="diagram-wrapper excalidraw-view">
        <ExcalidrawViewer client:only="react" elements={level1Elements} />
      </div>
      <div class="mermaid-wrapper mermaid-view">
        <div class="mermaid" set:text={mermaidDiagrams.level1}></div>
      </div>
      <div class="twoD-wrapper twoD-view">
        <HealthcarePlatform2D client:only="react" nodes={LEVEL_NODES[1]} connections={levelConnections.level1} />
      </div>
      <div class="threeD-wrapper threeD-view">
        <HealthcarePlatform3D client:only="react" nodes={LEVEL_NODES[1]} connections={levelConnections.level1} />
      </div>
    </section>

    <!-- Level 2: Container -->
    <section id="level2" class="tab-panel">
      <h2>Level 2 – Container</h2>
      <p class="description">
        Zooms in on the Healthcare Platform to show the containers (applications and data
        stores) that make it up.
      </p>
      <div class="diagram-wrapper excalidraw-view">
        <ExcalidrawViewer client:only="react" elements={level2Elements} />
      </div>
      <div class="mermaid-wrapper mermaid-view">
        <div class="mermaid" set:text={mermaidDiagrams.level2}></div>
      </div>
      <div class="twoD-wrapper twoD-view">
        <HealthcarePlatform2D client:only="react" nodes={LEVEL_NODES[2]} connections={levelConnections.level2} />
      </div>
      <div class="threeD-wrapper threeD-view">
        <HealthcarePlatform3D client:only="react" nodes={LEVEL_NODES[2]} connections={levelConnections.level2} />
      </div>
    </section>

    <!-- Level 3: Component -->
    <section id="level3" class="tab-panel">
      <h2>Level 3 – Component</h2>
      <p class="description">
        Zooms in on the EMR Service to show the components (controllers, services, and
        repositories) inside it.
      </p>
      <div class="diagram-wrapper excalidraw-view">
        <ExcalidrawViewer client:only="react" elements={level3Elements} />
      </div>
      <div class="mermaid-wrapper mermaid-view">
        <div class="mermaid" set:text={mermaidDiagrams.level3}></div>
      </div>
      <div class="twoD-wrapper twoD-view">
        <HealthcarePlatform2D client:only="react" nodes={LEVEL_NODES[3]} connections={levelConnections.level3} />
      </div>
      <div class="threeD-wrapper threeD-view">
        <HealthcarePlatform3D client:only="react" nodes={LEVEL_NODES[3]} connections={levelConnections.level3} />
      </div>
    </section>

    <!-- Level 4: Code -->
    <section id="level4" class="tab-panel">
      <h2>Level 4 – Code</h2>
      <p class="description">
        Zooms in on the Record Service to show the classes and interfaces that implement it.
      </p>
      <div class="diagram-wrapper excalidraw-view">
        <ExcalidrawViewer client:only="react" elements={level4Elements} />
      </div>
      <div class="mermaid-wrapper mermaid-view">
        <div class="mermaid" set:text={mermaidDiagrams.level4}></div>
      </div>
      <div class="twoD-wrapper twoD-view">
        <HealthcarePlatform2D client:only="react" nodes={LEVEL_NODES[4]} connections={levelConnections.level4} />
      </div>
      <div class="threeD-wrapper threeD-view">
        <HealthcarePlatform3D client:only="react" nodes={LEVEL_NODES[4]} connections={levelConnections.level4} />
      </div>
    </section>

    <script src="/Tooda/mermaid.min.js" is:inline></script>
    <script type="module">
      const { default: elkLayouts } = await import('/Tooda/mermaid-layout-elk.esm.min.mjs');
      mermaid.registerLayoutLoaders(elkLayouts);
      window._resolveElk();
    </script>
    <script is:inline>
      // ELK layout engine is loaded asynchronously; all mermaid.run() calls wait for it.
      window._elkReady = new Promise(resolve => { window._resolveElk = resolve; });

      mermaid.initialize({ startOnLoad: false, theme: 'default' });

      const tabs = document.querySelectorAll('.tab-btn');
      const panels = document.querySelectorAll('.tab-panel');
      const rendererBtns = document.querySelectorAll('.renderer-btn');
      const validTabs = ['level1', 'level2', 'level3', 'level4'];

      let currentRenderer = 'excalidraw';
      let currentLevel = 'level1';

      // ── Export PNG button ─────────────────────────────────────────────────────

      function updateExportPngBtn() {
        const container = document.getElementById('export-png-container');
        if (!container) return;
        if (currentRenderer === '3d') {
          container.style.display = 'none';
          return;
        }
        container.style.display = '';
        const btn = document.getElementById('export-png-btn');
        if (!btn) return;
        const href = '/Tooda/api/healthcare/' + currentRenderer + '/' + currentLevel + '.png';
        btn.setAttribute('href', href);
        btn.setAttribute('download', 'healthcare-' + currentRenderer + '-' + currentLevel + '.png');
      }

      // ── Renderer toggle ──────────────────────────────────────────────────────

      function activateRenderer(renderer) {
        if (renderer !== 'excalidraw' && renderer !== 'mermaid' && renderer !== '3d' && renderer !== '2d') renderer = 'excalidraw';
        currentRenderer = renderer;

        rendererBtns.forEach(b => b.classList.remove('active'));
        const activeBtn = document.querySelector('.renderer-btn[data-renderer="' + renderer + '"]');
        if (activeBtn) activeBtn.classList.add('active');

        const excalidrawViews = document.querySelectorAll('.excalidraw-view');
        const mermaidViews = document.querySelectorAll('.mermaid-view');
        const twoDViews = document.querySelectorAll('.twoD-view');
        const threeDViews = document.querySelectorAll('.threeD-view');

        excalidrawViews.forEach(el => { el.style.display = 'none'; });
        mermaidViews.forEach(el => { el.style.display = 'none'; });
        twoDViews.forEach(el => { el.style.display = 'none'; });
        threeDViews.forEach(el => { el.style.display = 'none'; });

        if (renderer === 'excalidraw') {
          excalidrawViews.forEach(el => { el.style.display = 'block'; });
        } else if (renderer === 'mermaid') {
          mermaidViews.forEach(el => { el.style.display = 'block'; });

          // Render any un-rendered Mermaid diagrams in the active panel
          const activePanel = document.querySelector('.tab-panel.active');
          if (activePanel) {
            const unrendered = Array.from(activePanel.querySelectorAll('.mermaid')).filter(
              el => !el.querySelector('svg')
            );
            if (unrendered.length > 0) {
              unrendered.forEach(el => el.removeAttribute('data-processed'));
              window._elkReady.then(() => mermaid.run({ nodes: unrendered }));
            }
          }
        } else if (renderer === '2d') {
          twoDViews.forEach(el => { el.style.display = 'block'; });
        } else {
          threeDViews.forEach(el => { el.style.display = 'block'; });
        }

        updateExportPngBtn();
      }

      rendererBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const renderer = btn.dataset.renderer;
          const url = new URL(window.location.href);
          url.searchParams.set('renderer', renderer);
          history.pushState(null, '', url.toString());
          activateRenderer(renderer);
        });
      });

      // ── Tab switching ─────────────────────────────────────────────────────────

      function activateTab(target) {
        if (!validTabs.includes(target)) target = 'level1';
        currentLevel = target;
        tabs.forEach(b => b.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        const activeBtn = document.querySelector('.tab-btn[data-tab="' + target + '"]');
        if (activeBtn) activeBtn.classList.add('active');
        const panel = document.getElementById(target);
        if (panel) {
          panel.classList.add('active');

          // Render any un-rendered Mermaid diagrams when switching tabs in Mermaid mode
          if (currentRenderer === 'mermaid') {
            const unrendered = Array.from(panel.querySelectorAll('.mermaid')).filter(
              el => !el.querySelector('svg')
            );
            if (unrendered.length > 0) {
              unrendered.forEach(el => el.removeAttribute('data-processed'));
              window._elkReady.then(() => mermaid.run({ nodes: unrendered }));
            }
          }
        }

        updateExportPngBtn();
      }

      tabs.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const target = btn.dataset.tab;
          history.pushState(null, '', '#' + target);
          activateTab(target);
        });
      });

      function activateFromHash() {
        const hash = window.location.hash.slice(1) || 'level1';
        activateTab(hash);
      }

      // ── Init from URL ─────────────────────────────────────────────────────────

      function activateFromQuery() {
        const params = new URLSearchParams(window.location.search);
        const renderer = params.get('renderer') || 'excalidraw';
        activateRenderer(renderer);
      }

      window.addEventListener('popstate', () => {
        activateFromQuery();
        activateFromHash();
      });

      window.addEventListener('hashchange', activateFromHash);

      activateFromQuery();
      activateFromHash();
    </script>
    </div>
    <script>
      const btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.setAttribute('aria-label', document.documentElement.classList.contains('dark') ? 'Switch to light mode' : 'Switch to dark mode');
        btn.addEventListener('click', function () {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
        });
      }
    </script>
  </body>
</html>
