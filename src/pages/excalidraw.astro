  // Arrows: API Gateway → services (fanning out downward only)
  ...makeArrow('l2-a5', 590, 185, 70,  -55, 'JSON/HTTPS'),
  ...makeArrow('l2-a6', 590, 200, 70,   50, 'JSON/HTTPS'),
  ...makeArrow('l2-a7', 590, 215, 70,  155, 'JSON/HTTPS'),
  // Arrows: services → data stores
  ...makeArrow('l2-a8',  820, 130, 70,  30, 'SQL'),
  ...makeArrow('l2-a9',  820, 250, 70, -90, 'SQL'),
  ...makeArrow('l2-a10', 820, 370, 70,   0, 'AMQP'),
