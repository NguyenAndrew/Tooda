---
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <meta name="description" content="Tooda – Tool to help make and maintain diagrams for architecture and design" />
    <title>Tooda</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme = stored === 'light' ? 'light' : 'dark';
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    <style>
      :root {
        --bg-color: #f8fafc;
        --grad1: rgba(20,184,166,0.15);
        --grad2: rgba(6,182,212,0.10);
        --grad3: rgba(16,185,129,0.07);
        --grid-line: rgba(20,184,166,0.04);
      }

      :root.dark {
        --bg-color: #0f172a;
        --grad1: rgba(20,184,166,0.28);
        --grad2: rgba(6,182,212,0.18);
        --grad3: rgba(16,185,129,0.14);
        --grid-line: rgba(20,184,166,0.08);
      }

      /* Animated gradient background */
      body {
        background-color: var(--bg-color);
        background-image:
          radial-gradient(ellipse 80% 60% at 50% -10%, var(--grad1) 0%, transparent 70%),
          radial-gradient(ellipse 50% 40% at 90% 80%, var(--grad2) 0%, transparent 60%),
          radial-gradient(ellipse 40% 40% at 10% 90%, var(--grad3) 0%, transparent 60%);
        @apply min-h-dvh font-sans text-slate-900 dark:text-slate-50;
      }

      /* Subtle animated grid */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--grid-line) 1px, transparent 1px),
          linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 0;
      }

      main {
        position: relative;
        z-index: 1;
      }

      /* Glowing title animation */
      @keyframes glow-pulse {
        0%, 100% { filter: drop-shadow(0 0 16px rgba(20,184,166,0.5)); }
        50%       { filter: drop-shadow(0 0 36px rgba(6,182,212,0.8)); }
      }

      .title-glow {
        animation: glow-pulse 3s ease-in-out infinite;
      }

      /* Floating badge animation */
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-6px); }
      }

      .badge-float {
        animation: float 4s ease-in-out infinite;
      }

      /* ── Feature card stagger entrance ── */
      @keyframes card-enter {
        from { opacity: 0; transform: translateY(22px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0)    scale(1);    }
      }

      .feature-card:nth-child(1) { animation: card-enter 0.55s cubic-bezier(0.22,1,0.36,1) 0.05s both; }
      .feature-card:nth-child(2) { animation: card-enter 0.55s cubic-bezier(0.22,1,0.36,1) 0.15s both; }
      .feature-card:nth-child(3) { animation: card-enter 0.55s cubic-bezier(0.22,1,0.36,1) 0.25s both; }
      .feature-card:nth-child(4) { animation: card-enter 0.55s cubic-bezier(0.22,1,0.36,1) 0.35s both; }
      .feature-card:nth-child(5) { animation: card-enter 0.55s cubic-bezier(0.22,1,0.36,1) 0.45s both; }

      /* ── Feature card shimmer sweep ── */
      @keyframes card-shimmer {
        0%   { left: -80%; }
        100% { left: 160%; }
      }

      /* CTA card styles */
      .feature-card {
        @apply relative overflow-hidden rounded-2xl border border-slate-200/80 bg-white/70 p-6 text-left backdrop-blur-sm transition-all duration-300 dark:border-slate-700/60 dark:bg-slate-800/60;
      }

      /* card icon (first div) – springy scale on hover */
      .feature-card > div:first-child {
        display: inline-block;
        transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
      }

      /* Hover effects are gated on (hover: hover) so that iOS Safari's
         sticky-hover behaviour does not trigger CSS transforms on tap,
         which would move elements mid-gesture and prevent navigation. */
      @media (hover: hover) {
        .feature-card:hover {
          border-color: rgba(20,184,166,0.55);
          transform: perspective(900px) rotateX(1.8deg) translateY(-8px);
          box-shadow:
            0 0 0 1px rgba(20,184,166,0.3),
            0 0 24px rgba(20,184,166,0.18),
            0 0 48px rgba(6,182,212,0.1),
            0 16px 40px rgba(0,0,0,0.1);
        }

        .feature-card:hover::before {
          opacity: 1;
        }

        /* shimmer sweep on hover */
        .feature-card:hover::after {
          animation: card-shimmer 0.75s cubic-bezier(0.4,0,0.2,1) forwards;
        }

        /* icon bounce on hover */
        .feature-card:hover > div:first-child {
          transform: scale(1.2) rotate(-5deg);
        }
      }

      .feature-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(20,184,166,0.08) 0%, rgba(6,182,212,0.04) 50%, transparent 70%);
        opacity: 0;
        transition: opacity 0.35s;
        pointer-events: none;
        z-index: 0;
      }

      /* shimmer pseudo-element */
      .feature-card::after {
        content: '';
        position: absolute;
        top: 0;
        left: -80%;
        width: 55%;
        height: 100%;
        background: linear-gradient(
          105deg,
          transparent 0%,
          rgba(255,255,255,0.14) 45%,
          rgba(255,255,255,0.22) 55%,
          transparent 100%
        );
        transform: skewX(-18deg);
        pointer-events: none;
        z-index: 1;
      }

      /* ── Primary CTA button ── */
      @keyframes btn-shimmer {
        0%   { left: -80%; }
        100% { left: 160%; }
      }

      @keyframes gradient-shift {
        0%   { background-position: 0% 50%; }
        50%  { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }

      .cta-primary {
        @apply relative inline-flex items-center gap-2 overflow-hidden rounded-full px-6 py-3 text-sm font-semibold text-white no-underline transition-all duration-200 active:scale-95 active:duration-75;
        background: linear-gradient(135deg, #14b8a6, #06b6d4, #10b981, #14b8a6);
        background-size: 200% 200%;
        animation: gradient-shift 4s ease infinite;
        box-shadow: 0 4px 14px rgba(20,184,166,0.35);
      }

      @media (prefers-reduced-motion: reduce) {
        .cta-primary {
          animation: none;
          background-size: 100% 100%;
        }
      }

      .cta-primary::after {
        content: '';
        position: absolute;
        top: 0;
        left: -80%;
        width: 55%;
        height: 100%;
        background: linear-gradient(
          105deg,
          transparent 0%,
          rgba(255,255,255,0.28) 45%,
          rgba(255,255,255,0.38) 55%,
          transparent 100%
        );
        transform: skewX(-20deg);
        pointer-events: none;
      }

      @media (hover: hover) {
        .cta-primary:hover {
          transform: translateY(-2px) scale(1.02);
          box-shadow:
            0 0 20px rgba(20,184,166,0.5),
            0 0 40px rgba(6,182,212,0.25),
            0 8px 24px rgba(20,184,166,0.3);
        }

        .cta-primary:hover::after {
          animation: btn-shimmer 0.6s cubic-bezier(0.4,0,0.2,1) forwards;
        }
      }

      /* GitHub link */
      .github-link {
        @apply inline-flex items-center gap-2 rounded-full border border-slate-300 px-5 py-2.5 text-sm text-slate-600 no-underline transition-all duration-200 active:scale-95 active:duration-75 dark:border-slate-700 dark:text-slate-400;
        background: rgba(255,255,255,0.5);
        backdrop-filter: blur(8px);
      }

      @media (hover: hover) {
        .github-link:hover {
          border-color: rgba(20,184,166,0.5);
          color: #0f766e;
          box-shadow: 0 0 12px rgba(20,184,166,0.2), 0 2px 8px rgba(0,0,0,0.06);
          transform: translateY(-1px);
        }

        :root.dark .github-link:hover {
          color: #5eead4;
        }
      }

      /* Theme toggle button */
      .theme-toggle-btn {
        @apply fixed right-4 top-4 z-50 flex h-10 w-10 items-center justify-center rounded-full border border-slate-300 bg-white/80 text-slate-600 shadow-md backdrop-blur-sm transition-all duration-200 dark:border-slate-700 dark:bg-slate-800/80 dark:text-slate-300;
      }

      @media (hover: hover) {
        .theme-toggle-btn:hover {
          border-color: rgba(20,184,166,0.6);
          box-shadow: 0 0 12px rgba(20,184,166,0.3), 0 2px 8px rgba(0,0,0,0.1);
          transform: rotate(15deg) scale(1.1);
        }
      }
    </style>
  </head>
  <body class="min-h-dvh font-sans">
    <!-- Theme toggle button -->
    <button id="theme-toggle" type="button" aria-label="Switch to light mode" class="theme-toggle-btn">
      <!-- Sun icon – shown in dark mode to switch to light -->
      <svg class="hidden size-5 dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <!-- Moon icon – shown in light mode to switch to dark -->
      <svg class="block size-5 dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <main class="mx-auto max-w-5xl px-6 py-20 text-center">

      <!-- Badge -->
      <div class="mb-8 flex justify-center">
        <span class="badge-float inline-flex items-center gap-2 rounded-full border border-teal-500/40 bg-teal-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-teal-700 dark:text-teal-300">
          ✦ Architecture &amp; Design Diagrams
        </span>
      </div>

      <!-- Hero heading -->
      <h1 class="title-glow mb-6 bg-gradient-to-br from-teal-400 via-cyan-400 to-emerald-400 bg-clip-text text-[clamp(3.5rem,10vw,7rem)] font-extrabold leading-none tracking-tight text-transparent">
        Tooda
      </h1>

      <!-- Tagline -->
      <p class="mx-auto mb-4 max-w-[52ch] text-[clamp(1.1rem,2.5vw,1.35rem)] leading-relaxed text-slate-600 dark:text-slate-300">
        Visualize, explore, and share your system architecture — all in the browser, no install required.
      </p>
      <p class="mx-auto mb-14 max-w-[44ch] text-base text-slate-500 dark:text-slate-500">
        Powered by Mermaid C4 and Excalidraw. Open-source.
      </p>

      <!-- Feature cards grid -->
      <div class="mb-12 grid gap-4 text-left sm:grid-cols-2 lg:grid-cols-3">

        <!-- C4 Diagrams card -->
        <div class="feature-card sm:col-span-2 lg:col-span-1">
          <div class="mb-3 text-3xl">🏗️</div>
          <h2 class="mb-1 text-lg font-bold text-slate-800 dark:text-slate-100">C4 Diagrams</h2>
          <p class="mb-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400">Interactive C4 architecture diagrams powered by Mermaid. Explore real-world system designs.</p>
          <div class="flex flex-wrap gap-2">
            <a href="/Tooda/c4?example=banking" class="cta-primary">🏦 Online Banking →</a>
          </div>
          <div class="mt-2 flex flex-wrap gap-2">
            <a href="/Tooda/c4?example=ecommerce" class="cta-primary">🛒 E-Commerce →</a>
            <a href="/Tooda/c4?example=ridesharing" class="cta-primary">🚗 Ride-Sharing →</a>
          </div>
          <div class="mt-2 flex flex-wrap gap-2">
            <a href="/Tooda/c4?example=tooda" class="cta-primary">🗂️ Tooda →</a>
          </div>
        </div>

        <!-- Excalidraw card -->
        <div class="feature-card">
          <div class="mb-3 text-3xl">✏️</div>
          <h2 class="mb-1 text-lg font-bold text-slate-800 dark:text-slate-100">Freehand Diagrams</h2>
          <p class="mb-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400">Sketch and annotate architecture freely with Excalidraw's hand-drawn aesthetic, or switch to Mermaid — both powered by a single source of truth.</p>
          <a href="/Tooda/excalidraw" class="cta-primary">🏥 Healthcare (Excalidraw / Mermaid) →</a>
        </div>

        <!-- API Explorer card -->
        <div class="feature-card">
          <div class="mb-3 text-3xl">🔌</div>
          <h2 class="mb-1 text-lg font-bold text-slate-800 dark:text-slate-100">API Explorer</h2>
          <p class="mb-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400">Inspect and test API endpoints interactively, right from the browser.</p>
          <a href="/Tooda/api" class="cta-primary">⚡ API Explorer →</a>
        </div>

        <!-- Features card -->
        <div class="feature-card sm:col-span-2 lg:col-span-2">
          <div class="mb-3 text-3xl">🔮</div>
          <h2 class="mb-1 text-lg font-bold text-slate-800 dark:text-slate-100">Explore Features</h2>
          <p class="mb-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400">See everything Tooda has to offer in an interactive 3D visualization.</p>
          <div class="flex flex-wrap gap-2">
            <a href="/Tooda/features" class="cta-primary">🔮 View All Features →</a>
          </div>
        </div>

        <!-- Slide Deck card -->
        <div class="feature-card">
          <div class="mb-3 text-3xl">🎞️</div>
          <h2 class="mb-1 text-lg font-bold text-slate-800 dark:text-slate-100">Slide Deck</h2>
          <p class="mb-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400">A guided overview of Tooda — what it is, how it works, and how to get started, presented as an interactive slide deck.</p>
          <a href="/Tooda/slideshow" class="cta-primary">🎞️ View Slide Deck →</a>
        </div>

      </div>

      <!-- Footer links -->
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="https://github.com/NguyenAndrew/Tooda" class="github-link" target="_blank" rel="noopener noreferrer">
          <svg class="size-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
          View on GitHub
        </a>
      </div>

    </main>
    <script>
      const btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.setAttribute('aria-label', document.documentElement.classList.contains('dark') ? 'Switch to light mode' : 'Switch to dark mode');
        btn.addEventListener('click', function () {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
        });
      }
    </script>
  </body>
</html>
