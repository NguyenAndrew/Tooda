---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tooda – Tool to help make and maintain diagrams for architecture and design" />
    <title>Tooda</title>
    <style>
      .cta {
        @apply inline-block min-w-48 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-400 px-7 py-3 text-base font-semibold text-white no-underline transition-opacity duration-200;
      }

      .cta:hover {
        @apply opacity-85;
      }
    </style>
  </head>
  <body class="grid min-h-dvh place-items-center bg-slate-900 font-sans text-slate-50">
    <main class="p-8 text-center">
      <h1 class="mb-4 bg-gradient-to-br from-indigo-500 via-violet-400 to-sky-400 bg-clip-text text-[clamp(2.5rem,8vw,5rem)] font-extrabold text-transparent">Tooda</h1>
      <p class="max-w-[55ch] text-[clamp(1rem,2.5vw,1.25rem)] leading-relaxed text-slate-400">Welcome to Tooda — your tool for architecture and design diagrams.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/Tooda/c4?example=banking" class="cta">Online Banking →</a>
        <a href="/Tooda/c4?example=ecommerce" class="cta">E-Commerce →</a>
        <a href="/Tooda/c4?example=ridesharing" class="cta">Ride-Sharing →</a>
        <a href="/Tooda/excalidraw" class="cta">Healthcare (Excalidraw) →</a>
        <a href="/Tooda/api" class="cta">API Explorer →</a>
      </div>
    </main>
  </body>
</html>
